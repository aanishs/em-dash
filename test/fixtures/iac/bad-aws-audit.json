{
  "resource": {
    "aws_cloudtrail": {
      "main_trail": {
        "name": "main-trail",
        "s3_bucket_name": "trail-bucket"
      }
    },
    "aws_vpc": {
      "main_vpc": {
        "cidr_block": "10.0.0.0/16"
      }
    },
    "aws_cloudwatch_log_group": {
      "short_retention": {
        "name": "/aws/lambda/my-func",
        "retention_in_days": 30
      },
      "no_retention": {
        "name": "/aws/lambda/other-func"
      }
    }
  }
}
