# Copy to .env and fill in real values — NEVER commit .env with real secrets
# All secrets should be managed via a secrets manager (e.g., AWS Secrets Manager)

DATABASE_URL=postgresql://user:CHANGE_ME@localhost:5432/patients?sslmode=verify-full
AWS_ACCESS_KEY_ID=<from-aws-iam>
AWS_SECRET_ACCESS_KEY=<from-aws-iam>
STRIPE_SECRET_KEY=<from-stripe-dashboard>
JWT_SECRET=<generate-with-openssl-rand-hex-32>
ANTHROPIC_API_KEY=<from-anthropic-console>
