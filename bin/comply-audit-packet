#!/usr/bin/env bun
/**
 * comply-audit-packet — Generate signed audit packet ZIP.
 *
 * Collects attestations and evidence into a self-verifying ZIP archive
 * that can be shared with auditors, investors, or customers.
 *
 * Usage:
 *   comply-audit-packet --attestation-dir DIR --output PATH
 *     [--include-evidence]         Include full evidence files (default: hashes only)
 *     [--redact]                   Redact sensitive data (AWS account IDs, ARNs, IPs) from evidence
 *     [--evidence-dir DIR]         Evidence directory (default: auto-detect)
 *     [--public-key PATH]          Include specific public key
 */

import * as fs from 'fs';
import * as path from 'path';
import * as crypto from 'crypto';

const args = process.argv.slice(2);

function getFlag(name: string): string {
  const idx = args.indexOf(`--${name}`);
  if (idx === -1 || idx + 1 >= args.length) return '';
  return args[idx + 1];
}

function hasFlag(name: string): boolean {
  return args.includes(`--${name}`);
}

function sha256(data: Buffer | string): string {
  return crypto.createHash('sha256').update(data).digest('hex');
}

function getToolVersion(): string {
  try {
    const pkg = JSON.parse(fs.readFileSync(path.join(import.meta.dir, '..', 'package.json'), 'utf-8'));
    return pkg.version || 'unknown';
  } catch {
    return 'unknown';
  }
}

// ─── Main ───────────────────────────────────────────────────

/**
 * Redact sensitive data patterns from evidence text.
 * Covers: AWS account IDs, ARNs, IP addresses, access keys.
 */
function redactSensitiveData(text: string): string {
  return text
    // AWS Account IDs (12-digit numbers)
    .replace(/\b\d{12}\b/g, '[REDACTED-ACCOUNT-ID]')
    // AWS ARNs
    .replace(/arn:aws[a-z\-]*:[a-z0-9\-]+:[a-z0-9\-]*:\d{12}:[^\s"',}\]]+/gi, '[REDACTED-ARN]')
    // AWS Access Key IDs
    .replace(/AKIA[A-Z0-9]{16}/g, '[REDACTED-ACCESS-KEY]')
    // AWS Secret Keys (base64-like, 40 chars after common prefixes)
    .replace(/(?<=secret[_\-]?(?:access)?[_\-]?key['":\s=]+)[A-Za-z0-9/+=]{40}/gi, '[REDACTED-SECRET]')
    // IPv4 addresses (but not version numbers like 1.2.3)
    .replace(/\b(?:(?:25[0-5]|2[0-4]\d|[01]?\d\d?)\.){3}(?:25[0-5]|2[0-4]\d|[01]?\d\d?)\b/g, '[REDACTED-IP]')
    // IPv6 addresses
    .replace(/\b(?:[0-9a-f]{1,4}:){7}[0-9a-f]{1,4}\b/gi, '[REDACTED-IPv6]')
    // S3 bucket names in URLs
    .replace(/s3:\/\/[a-z0-9][a-z0-9.\-]{1,61}[a-z0-9]/gi, 's3://[REDACTED-BUCKET]')
    // EC2 instance IDs
    .replace(/i-[0-9a-f]{8,17}/g, '[REDACTED-INSTANCE]')
    // VPC IDs
    .replace(/vpc-[0-9a-f]{8,17}/g, '[REDACTED-VPC]')
    // Subnet IDs
    .replace(/subnet-[0-9a-f]{8,17}/g, '[REDACTED-SUBNET]')
    // Security Group IDs
    .replace(/sg-[0-9a-f]{8,17}/g, '[REDACTED-SG]');
}

const attestationDir = getFlag('attestation-dir');
const output = getFlag('output');
const includeEvidence = hasFlag('include-evidence');
const redactEvidence = hasFlag('redact');
const evidenceDir = getFlag('evidence-dir');
const publicKeyPath = getFlag('public-key') || path.join(process.env.HOME ?? '', '.em-dash', 'keys', 'default.pub');

if (!attestationDir || !output) {
  console.error('Usage: comply-audit-packet --attestation-dir DIR --output PATH [--include-evidence] [--evidence-dir DIR]');
  process.exit(1);
}

if (!fs.existsSync(attestationDir)) {
  console.error(`Attestation directory not found: ${attestationDir}`);
  process.exit(1);
}

// Collect attestation files
const attestationFiles = fs.readdirSync(attestationDir)
  .filter((f: string) => f.endsWith('.json'));

if (attestationFiles.length === 0) {
  console.error('No attestation files found in ' + attestationDir);
  process.exit(1);
}

// Find session attestation
let sessionData: Record<string, unknown> | null = null;
for (const file of attestationFiles) {
  const data = JSON.parse(fs.readFileSync(path.join(attestationDir, file), 'utf-8'));
  if (data.type === 'session') {
    sessionData = data;
    break;
  }
}

// Validate all attestation references before creating packet
const checkFiles = attestationFiles.filter((f: string) => f.startsWith('check-'));
const missingEvidence: string[] = [];

if (includeEvidence && evidenceDir) {
  for (const file of checkFiles) {
    const data = JSON.parse(fs.readFileSync(path.join(attestationDir, file), 'utf-8'));
    if (data.evidence_hash && data.evidence_hash !== '') {
      // Evidence hash exists but we'd need the actual file — check later
    }
  }
}

// Generate human-readable summary
const checks: Array<{ id: string; result: string; requirement: string; applicability: string }> = [];
for (const file of checkFiles) {
  const data = JSON.parse(fs.readFileSync(path.join(attestationDir, file), 'utf-8'));
  checks.push({
    id: data.check_id || 'unknown',
    result: data.result || 'unknown',
    requirement: data.requirement_id || '',
    applicability: data.applicability || 'required',
  });
}

const passed = checks.filter((c) => c.result === 'PASS').length;
const failed = checks.filter((c) => c.result === 'FAIL').length;
const skipped = checks.filter((c) => c.result === 'SKIP').length;

const scope = sessionData?.scope as Record<string, unknown> | undefined;
const environment = sessionData?.environment as Record<string, unknown> | undefined;
const signer = sessionData?.signer as Record<string, unknown> | undefined;
const run = sessionData?.run as Record<string, unknown> | undefined;

const summary = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>em-dash Audit Packet</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; color: #1a1a1a; }
    h1 { border-bottom: 2px solid #1a1a1a; padding-bottom: 0.5rem; }
    .meta { color: #666; font-size: 0.9rem; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th, td { padding: 0.5rem; text-align: left; border-bottom: 1px solid #ddd; }
    th { background: #f5f5f5; }
    .pass { color: #16a34a; font-weight: bold; }
    .fail { color: #dc2626; font-weight: bold; }
    .skip { color: #9ca3af; }
    .addressable { font-style: italic; color: #6b7280; }
    .stats { display: flex; gap: 2rem; margin: 1rem 0; }
    .stat { text-align: center; }
    .stat-num { font-size: 2rem; font-weight: bold; }
    .disclaimer { background: #fef3c7; padding: 1rem; border-radius: 4px; margin: 1rem 0; font-size: 0.85rem; }
    .verify { background: #f0fdf4; padding: 1rem; border-radius: 4px; margin: 1rem 0; }
    code { background: #f5f5f5; padding: 0.1rem 0.3rem; border-radius: 2px; font-size: 0.85rem; }
  </style>
</head>
<body>
  <h1>em-dash Compliance Audit Packet</h1>

  <div class="disclaimer">
    This report was generated by em-dash and is NOT legal advice. It does not constitute
    HIPAA certification. Consult qualified legal counsel for formal compliance verification.
  </div>

  <div class="meta">
    <p>Generated: ${new Date().toISOString()}</p>
    <p>Tool: em-dash v${getToolVersion()}</p>
    <p>Framework: ${scope?.framework ?? 'hipaa'} | Profile: ${scope?.profile ?? 'unknown'}</p>
    <p>Signer: ${signer?.identity ?? 'unknown'} (${signer?.key_fingerprint ?? 'no key'})</p>
    ${run ? `<p>Scan window: ${run.started_at} → ${run.completed_at}</p>` : ''}
  </div>

  <h2>Results Summary</h2>
  <div class="stats">
    <div class="stat"><div class="stat-num pass">${passed}</div>Passed</div>
    <div class="stat"><div class="stat-num fail">${failed}</div>Failed</div>
    <div class="stat"><div class="stat-num skip">${skipped}</div>Skipped</div>
    <div class="stat"><div class="stat-num">${checks.length}</div>Total</div>
  </div>

  <h2>Check Details</h2>
  <table>
    <thead>
      <tr><th>Check</th><th>Requirement</th><th>Applicability</th><th>Result</th></tr>
    </thead>
    <tbody>
      ${checks
        .map(
          (c) =>
            `<tr>
          <td>${c.id}</td>
          <td>${c.requirement}</td>
          <td>${c.applicability === 'addressable' ? '<span class="addressable">addressable</span>' : 'required'}</td>
          <td><span class="${c.result.toLowerCase()}">${c.result}</span></td>
        </tr>`,
        )
        .join('\n')}
    </tbody>
  </table>

  <div class="verify">
    <h3>Verification</h3>
    <p>This packet is cryptographically signed. To verify:</p>
    <ol>
      <li>Extract the ZIP archive</li>
      <li>Install em-dash: <code>git clone https://github.com/user/hipaa-audit && cd hipaa-audit && ./setup</code></li>
      <li>Run: <code>bin/comply-verify --attestation-dir attestations/ --public-key public-key.pub</code></li>
    </ol>
    <p>Or verify manually: each attestation JSON contains a <code>signature</code> field.
    Remove the signature, canonicalize the remaining JSON per RFC 8785, and verify
    the Ed25519 signature against the included public key.</p>
  </div>
</body>
</html>`;

// Build ZIP using Bun's built-in approach (tar + gzip fallback)
// For now, create a directory structure and use system zip
const tmpDir = fs.mkdtempSync(path.join(require('os').tmpdir(), 'emdash-packet-'));
const packetDir = path.join(tmpDir, 'audit-packet');

try {
  // Create directory structure
  fs.mkdirSync(path.join(packetDir, 'attestations'), { recursive: true });

  // Copy attestation files
  for (const file of attestationFiles) {
    fs.copyFileSync(path.join(attestationDir, file), path.join(packetDir, 'attestations', file));
  }

  // Write summary
  fs.writeFileSync(path.join(packetDir, 'summary.html'), summary);

  // Copy public key
  if (fs.existsSync(publicKeyPath)) {
    fs.copyFileSync(publicKeyPath, path.join(packetDir, 'public-key.pub'));
  }

  // Write verification instructions
  fs.writeFileSync(
    path.join(packetDir, 'VERIFY.md'),
    `# Verification Instructions

This audit packet was generated by em-dash and signed with Ed25519.

## Quick Verify
\`\`\`bash
bin/comply-verify --attestation-dir attestations/ --public-key public-key.pub
\`\`\`

## Manual Verify
Each attestation JSON has a \`signature\` field. To verify:
1. Parse the JSON and extract the \`signature\` value
2. Remove the \`signature\` field from the object
3. Canonicalize the remaining JSON per RFC 8785 (JCS)
4. Verify the Ed25519 signature using the public key in \`public-key.pub\`

## Contents
- \`attestations/\` — Signed check and session attestations (JSON)
- \`summary.html\` — Human-readable compliance report
- \`public-key.pub\` — Ed25519 public key for verification
- \`VERIFY.md\` — This file
${includeEvidence ? '- `evidence/` — Raw evidence files\n' : ''}
`,
  );

  // Include evidence if requested
  if (includeEvidence && evidenceDir && fs.existsSync(evidenceDir)) {
    fs.mkdirSync(path.join(packetDir, 'evidence'), { recursive: true });
    const evidenceFiles = fs.readdirSync(evidenceDir);
    for (const file of evidenceFiles) {
      const src = path.join(evidenceDir, file);
      if (fs.statSync(src).isFile()) {
        if (redactEvidence) {
          // Read, redact, write — don't copy binary files
          const ext = path.extname(file).toLowerCase();
          const textExts = ['.json', '.txt', '.log', '.csv', '.yaml', '.yml', '.xml', '.tf', '.md'];
          if (textExts.includes(ext)) {
            const content = fs.readFileSync(src, 'utf-8');
            fs.writeFileSync(path.join(packetDir, 'evidence', file), redactSensitiveData(content));
          } else {
            fs.copyFileSync(src, path.join(packetDir, 'evidence', file));
          }
        } else {
          fs.copyFileSync(src, path.join(packetDir, 'evidence', file));
        }
      }
    }
  }

  // Create ZIP using system zip command
  const outputPath = path.resolve(output);
  const outputDir = path.dirname(outputPath);
  if (!fs.existsSync(outputDir)) fs.mkdirSync(outputDir, { recursive: true });

  // Write to temp file first, then rename (atomic write for disk-full safety)
  const tmpOutput = outputPath + '.tmp';
  const proc = Bun.spawnSync(['zip', '-r', '-q', tmpOutput, 'audit-packet'], {
    cwd: tmpDir,
    stdout: 'pipe',
    stderr: 'pipe',
  });

  if (proc.exitCode !== 0) {
    const stderr = proc.stderr.toString();
    // Clean up temp file on failure
    try { fs.unlinkSync(tmpOutput); } catch {}
    console.error(`Failed to create ZIP: ${stderr}`);
    process.exit(1);
  }

  // Atomic rename
  fs.renameSync(tmpOutput, outputPath);

  const stat = fs.statSync(outputPath);
  const sizeKb = (stat.size / 1024).toFixed(1);
  console.log(`AUDIT_PACKET_CREATED: ${outputPath} (${sizeKb} KB)`);
  console.log(`  Attestations: ${attestationFiles.length} files`);
  console.log(`  Checks: ${passed} passed, ${failed} failed, ${skipped} skipped`);
  console.log(`  Evidence: ${includeEvidence ? 'included' : 'hashes only'}`);

} finally {
  // Clean up temp directory
  fs.rmSync(tmpDir, { recursive: true, force: true });
}
