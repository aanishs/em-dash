#!/usr/bin/env bash
# emdash-update-check — check if a newer version of em-dash is available
# Usage: emdash-update-check
# Output: UPGRADE_AVAILABLE <current> <latest>  (if newer version exists)
#         JUST_UPGRADED                          (if version changed since last check)
#         (nothing)                              (if up to date or check skipped)
set -uo pipefail

STATE_DIR="${HOME}/.em-dash"
CACHE_FILE="$STATE_DIR/.update-cache"
SNOOZE_FILE="$STATE_DIR/.update-snoozed"

# Find package.json relative to this script
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PKG_JSON="$SCRIPT_DIR/../package.json"

# Read current version
if [ ! -f "$PKG_JSON" ]; then
  exit 0
fi
CURRENT=$(grep '"version"' "$PKG_JSON" 2>/dev/null | head -1 | sed 's/.*"\([0-9][0-9.]*\)".*/\1/')
if [ -z "$CURRENT" ]; then
  exit 0
fi

# Check snooze
if [ -f "$SNOOZE_FILE" ]; then
  SNOOZE_UNTIL=$(cat "$SNOOZE_FILE" 2>/dev/null)
  NOW=$(date +%s)
  if [ "$NOW" -lt "${SNOOZE_UNTIL:-0}" ] 2>/dev/null; then
    exit 0
  fi
fi

# Check cache (TTL: 60 minutes)
if [ -f "$CACHE_FILE" ]; then
  CACHE_AGE=$(( $(date +%s) - $(stat -f %m "$CACHE_FILE" 2>/dev/null || stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0) ))
  if [ "$CACHE_AGE" -lt 3600 ]; then
    CACHED=$(cat "$CACHE_FILE")
    if [ "$CACHED" = "UP_TO_DATE" ]; then
      exit 0
    elif [ "$CACHED" != "$CURRENT" ] && [ -n "$CACHED" ]; then
      echo "UPGRADE_AVAILABLE $CURRENT $CACHED"
      exit 0
    fi
    exit 0
  fi
fi

# Check for latest version via git tags (non-blocking, 3s timeout)
LATEST=$(git ls-remote --tags --sort=-v:refname origin 2>/dev/null | head -1 | sed 's|.*refs/tags/v\{0,1\}||;s/\^{}//' || true)

if [ -z "$LATEST" ]; then
  # No remote or no tags — skip
  mkdir -p "$STATE_DIR"
  echo "UP_TO_DATE" > "$CACHE_FILE"
  exit 0
fi

mkdir -p "$STATE_DIR"

if [ "$CURRENT" = "$LATEST" ]; then
  echo "UP_TO_DATE" > "$CACHE_FILE"
  exit 0
fi

# Simple version comparison (works for semver)
echo "$LATEST" > "$CACHE_FILE"
echo "UPGRADE_AVAILABLE $CURRENT $LATEST"
