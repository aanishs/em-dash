#!/usr/bin/env bun
/**
 * hipaa-attest — Ed25519 attestation signer for em-dash compliance checks.
 *
 * Subcommands:
 *   init-keys                    Generate Ed25519 keypair at ~/.em-dash/keys/
 *   check --check-id ID          Sign a per-check attestation
 *         --requirement-id ID
 *         --result PASS|FAIL
 *         --evidence-hash HASH
 *         [--oscal-refs AC-2,IA-2]
 *         [--applicability required|addressable]
 *         --output PATH
 *   session --attestation-dir DIR Sign a session attestation wrapping check attestations
 *           --framework hipaa
 *           --profile PROFILE
 *           --controls-in-scope N
 *           [--checks-skipped JSON]
 *           --output PATH
 *   verify  --attestation PATH    Verify a single attestation signature
 *           [--public-key PATH]
 *
 * Keys: ~/.em-dash/keys/default.pem (private), ~/.em-dash/keys/default.pub (public)
 */

import * as fs from 'fs';
import * as path from 'path';
import * as crypto from 'crypto';
import canonicalize from 'canonicalize';

const KEYS_DIR = path.join(process.env.HOME ?? '', '.em-dash', 'keys');
const PRIVATE_KEY_PATH = path.join(KEYS_DIR, 'default.pem');
const PUBLIC_KEY_PATH = path.join(KEYS_DIR, 'default.pub');

const args = process.argv.slice(2);
const subcommand = args[0];

if (!subcommand) {
  console.error('Usage: hipaa-attest <init-keys|check|session|verify> [args]');
  process.exit(1);
}

// ─── Helpers ────────────────────────────────────────────────

function getFlag(name: string): string {
  const idx = args.indexOf(`--${name}`);
  if (idx === -1 || idx + 1 >= args.length) return '';
  return args[idx + 1];
}

function hasFlag(name: string): boolean {
  return args.includes(`--${name}`);
}

function sha256(data: Buffer | string): string {
  return crypto.createHash('sha256').update(data).digest('hex');
}

/**
 * Canonicalize and sign a JSON object using RFC 8785 (JCS).
 * The signature covers the canonical byte representation, ensuring
 * cross-runtime verification compatibility.
 */
function signObject(obj: Record<string, unknown>, privateKey: crypto.KeyObject): string {
  const canonical = canonicalize(obj);
  if (!canonical) throw new Error('Failed to canonicalize attestation JSON');
  const signature = crypto.sign(null, Buffer.from(canonical), privateKey);
  return signature.toString('base64');
}

function verifySignature(
  obj: Record<string, unknown>,
  signature: string,
  publicKey: crypto.KeyObject,
): boolean {
  const canonical = canonicalize(obj);
  if (!canonical) return false;
  return crypto.verify(null, Buffer.from(canonical), publicKey, Buffer.from(signature, 'base64'));
}

function loadPrivateKey(): crypto.KeyObject {
  if (!fs.existsSync(PRIVATE_KEY_PATH)) {
    console.error(`No signing key found at ${PRIVATE_KEY_PATH}`);
    console.error('Run: hipaa-attest init-keys');
    process.exit(1);
  }
  checkKeyPermissions(PRIVATE_KEY_PATH);
  const pem = fs.readFileSync(PRIVATE_KEY_PATH, 'utf-8');
  return crypto.createPrivateKey(pem);
}

function loadPublicKey(customPath?: string): crypto.KeyObject {
  const keyPath = customPath || PUBLIC_KEY_PATH;
  if (!fs.existsSync(keyPath)) {
    console.error(`No public key found at ${keyPath}`);
    process.exit(1);
  }
  const pem = fs.readFileSync(keyPath, 'utf-8');
  return crypto.createPublicKey(pem);
}

function checkKeyPermissions(filePath: string): void {
  try {
    const stat = fs.statSync(filePath);
    const mode = stat.mode & 0o777;
    if (mode & 0o077) {
      console.error(`WARNING: Key file ${filePath} has permissions ${mode.toString(8)}`);
      console.error('Key file is accessible by other users. Run: chmod 600 ' + filePath);
      process.exit(1);
    }
  } catch {
    // Skip permission check on systems that don't support it
  }
}

function keyFingerprint(publicKey: crypto.KeyObject): string {
  const der = publicKey.export({ type: 'spki', format: 'der' });
  return 'ed25519:' + sha256(der).slice(0, 16);
}

function getToolVersion(): string {
  try {
    const pkg = JSON.parse(fs.readFileSync(path.join(import.meta.dir, '..', 'package.json'), 'utf-8'));
    return pkg.version || 'unknown';
  } catch {
    return 'unknown';
  }
}

// ─── Subcommands ────────────────────────────────────────────

async function initKeys(): Promise<void> {
  if (fs.existsSync(PRIVATE_KEY_PATH)) {
    console.log('Keys already exist at ' + KEYS_DIR);
    console.log('Fingerprint: ' + keyFingerprint(loadPublicKey()));
    return;
  }

  fs.mkdirSync(KEYS_DIR, { recursive: true });

  const { publicKey, privateKey } = crypto.generateKeyPairSync('ed25519');

  const privatePem = privateKey.export({ type: 'pkcs8', format: 'pem' }) as string;
  const publicPem = publicKey.export({ type: 'spki', format: 'pem' }) as string;

  fs.writeFileSync(PRIVATE_KEY_PATH, privatePem, { mode: 0o600 });
  fs.writeFileSync(PUBLIC_KEY_PATH, publicPem, { mode: 0o644 });

  const fp = keyFingerprint(publicKey);
  console.log('Generated Ed25519 keypair at ' + KEYS_DIR);
  console.log('Fingerprint: ' + fp);
  console.log('Private key: ' + PRIVATE_KEY_PATH + ' (chmod 600)');
  console.log('Public key:  ' + PUBLIC_KEY_PATH);
}

function attestCheck(): void {
  const checkId = getFlag('check-id');
  const requirementId = getFlag('requirement-id');
  const result = getFlag('result');
  const evidenceHash = getFlag('evidence-hash');
  const output = getFlag('output');
  const oscalRefsStr = getFlag('oscal-refs');
  const applicability = getFlag('applicability') || 'required';

  if (!checkId || !requirementId || !result || !output) {
    console.error('Usage: hipaa-attest check --check-id ID --requirement-id ID --result PASS|FAIL --evidence-hash HASH --output PATH');
    process.exit(1);
  }

  if (result !== 'PASS' && result !== 'FAIL' && result !== 'SKIP') {
    console.error('Result must be PASS, FAIL, or SKIP');
    process.exit(1);
  }

  const privateKey = loadPrivateKey();
  const publicKey = crypto.createPublicKey(privateKey);
  const fp = keyFingerprint(publicKey);

  const attestation: Record<string, unknown> = {
    type: 'check',
    version: '1.0',
    check_id: checkId,
    requirement_id: requirementId,
    applicability,
    result,
    evidence_hash: evidenceHash || '',
    timestamp: new Date().toISOString(),
    signer: { key_fingerprint: fp },
  };

  if (oscalRefsStr) {
    attestation.oscal_refs = oscalRefsStr.split(',').map((s: string) => s.trim());
  }

  attestation.signature = signObject(attestation, privateKey);

  const outputDir = path.dirname(output);
  if (!fs.existsSync(outputDir)) fs.mkdirSync(outputDir, { recursive: true });
  fs.writeFileSync(output, JSON.stringify(attestation, null, 2));
  console.log(`CHECK_ATTESTATION_CREATED: ${checkId} ${result} → ${output}`);
}

function attestSession(): void {
  const attestationDir = getFlag('attestation-dir');
  const framework = getFlag('framework') || 'hipaa';
  const profile = getFlag('profile') || `${framework}-sp800-66r2-v1`;
  const controlsInScope = parseInt(getFlag('controls-in-scope') || '0', 10);
  const checksSkippedStr = getFlag('checks-skipped');
  const output = getFlag('output');

  if (!attestationDir || !output) {
    console.error('Usage: hipaa-attest session --attestation-dir DIR --framework hipaa --controls-in-scope N --output PATH');
    process.exit(1);
  }

  // Collect check attestations from directory
  const checkFiles = fs.readdirSync(attestationDir)
    .filter((f: string) => f.startsWith('check-') && f.endsWith('.json'));

  if (checkFiles.length === 0) {
    console.error('No check attestations found in ' + attestationDir);
    console.error('Cannot create session attestation with 0 checks.');
    process.exit(1);
  }

  const checkHashes: string[] = [];
  let controlsChecked = 0;

  for (const file of checkFiles) {
    const content = fs.readFileSync(path.join(attestationDir, file), 'utf-8');
    checkHashes.push('sha256:' + sha256(content));
    controlsChecked++;
  }

  const privateKey = loadPrivateKey();
  const publicKey = crypto.createPublicKey(privateKey);
  const fp = keyFingerprint(publicKey);

  let checksSkipped: Array<{ check_id: string; reason: string }> = [];
  if (checksSkippedStr) {
    try {
      checksSkipped = JSON.parse(checksSkippedStr);
    } catch {
      console.error('Invalid --checks-skipped JSON');
      process.exit(1);
    }
  }

  const session: Record<string, unknown> = {
    type: 'session',
    version: '1.0',
    scope: {
      framework,
      profile,
      controls_in_scope: controlsInScope || controlsChecked,
      controls_checked: controlsChecked,
      checks_skipped: checksSkipped,
    },
    environment: {
      tool: 'em-dash',
      tool_version: getToolVersion(),
      platform: process.platform,
    },
    run: {
      started_at: new Date().toISOString(),
      completed_at: new Date().toISOString(),
    },
    check_attestation_hashes: checkHashes.sort(),
    signer: {
      key_fingerprint: fp,
      identity: `${process.env.USER || 'unknown'}@local`,
    },
  };

  session.signature = signObject(session, privateKey);

  const outputDir = path.dirname(output);
  if (!fs.existsSync(outputDir)) fs.mkdirSync(outputDir, { recursive: true });
  fs.writeFileSync(output, JSON.stringify(session, null, 2));
  console.log(`SESSION_ATTESTATION_CREATED: ${controlsChecked} checks → ${output}`);
}

function verifyAttestation(): void {
  const attestationPath = getFlag('attestation');
  const publicKeyPath = getFlag('public-key') || '';

  if (!attestationPath) {
    console.error('Usage: hipaa-attest verify --attestation PATH [--public-key PATH]');
    process.exit(1);
  }

  if (!fs.existsSync(attestationPath)) {
    console.error(`Attestation file not found: ${attestationPath}`);
    process.exit(1);
  }

  let attestation: Record<string, unknown>;
  try {
    attestation = JSON.parse(fs.readFileSync(attestationPath, 'utf-8'));
  } catch {
    console.error(`Malformed attestation JSON: ${attestationPath}`);
    process.exit(1);
  }

  const signature = attestation.signature as string;
  if (!signature) {
    console.error('Attestation has no signature field');
    process.exit(1);
  }

  // Remove signature before verification (signature covers all other fields)
  const { signature: _, ...payload } = attestation;

  const publicKey = loadPublicKey(publicKeyPath || undefined);

  const valid = verifySignature(payload, signature, publicKey);
  if (valid) {
    console.log(`VERIFIED: ${attestation.type} attestation at ${attestationPath}`);
    process.exit(0);
  } else {
    console.error(`VERIFICATION_FAILED: signature invalid for ${attestationPath}`);
    process.exit(1);
  }
}

// ─── Router ─────────────────────────────────────────────────

switch (subcommand) {
  case 'init-keys':
    await initKeys();
    break;
  case 'check':
    attestCheck();
    break;
  case 'session':
    attestSession();
    break;
  case 'verify':
    verifyAttestation();
    break;
  default:
    console.error(`Unknown subcommand: ${subcommand}`);
    console.error('Usage: hipaa-attest <init-keys|check|session|verify> [args]');
    process.exit(1);
}
