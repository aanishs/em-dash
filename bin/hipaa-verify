#!/usr/bin/env bun
/**
 * hipaa-verify — Verify em-dash attestation integrity.
 *
 * Verifies both session-level and check-level attestations. For session
 * attestations, validates that all referenced check attestations exist
 * and their hashes match.
 *
 * Usage:
 *   hipaa-verify --attestation-dir DIR   Verify all attestations in a directory
 *   hipaa-verify --file PATH             Verify a single attestation file
 *   [--public-key PATH]                  Custom public key (default: ~/.em-dash/keys/default.pub)
 */

import * as fs from 'fs';
import * as path from 'path';
import * as crypto from 'crypto';
import canonicalize from 'canonicalize';

const KEYS_DIR = path.join(process.env.HOME ?? '', '.em-dash', 'keys');
const PUBLIC_KEY_PATH = path.join(KEYS_DIR, 'default.pub');

const args = process.argv.slice(2);

function getFlag(name: string): string {
  const idx = args.indexOf(`--${name}`);
  if (idx === -1 || idx + 1 >= args.length) return '';
  return args[idx + 1];
}

function sha256(data: Buffer | string): string {
  return crypto.createHash('sha256').update(data).digest('hex');
}

function loadPublicKey(customPath?: string): crypto.KeyObject {
  const keyPath = customPath || PUBLIC_KEY_PATH;
  if (!fs.existsSync(keyPath)) {
    console.error(`No public key found at ${keyPath}`);
    process.exit(1);
  }
  return crypto.createPublicKey(fs.readFileSync(keyPath, 'utf-8'));
}

function verifySignature(
  obj: Record<string, unknown>,
  signature: string,
  publicKey: crypto.KeyObject,
): boolean {
  const canonical = canonicalize(obj);
  if (!canonical) return false;
  return crypto.verify(null, Buffer.from(canonical), publicKey, Buffer.from(signature, 'base64'));
}

interface VerifyResult {
  file: string;
  type: string;
  valid: boolean;
  error?: string;
}

function verifySingleFile(filePath: string, publicKey: crypto.KeyObject): VerifyResult {
  const basename = path.basename(filePath);

  if (!fs.existsSync(filePath)) {
    return { file: basename, type: 'unknown', valid: false, error: 'File not found' };
  }

  let attestation: Record<string, unknown>;
  try {
    attestation = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
  } catch {
    return { file: basename, type: 'unknown', valid: false, error: 'Invalid JSON' };
  }

  const signature = attestation.signature as string;
  if (!signature) {
    return { file: basename, type: String(attestation.type ?? 'unknown'), valid: false, error: 'No signature field' };
  }

  const { signature: _, ...payload } = attestation;
  const valid = verifySignature(payload, signature, publicKey);

  return {
    file: basename,
    type: String(attestation.type ?? 'unknown'),
    valid,
    error: valid ? undefined : 'Signature verification failed',
  };
}

function verifyDirectory(dir: string, publicKey: crypto.KeyObject): void {
  if (!fs.existsSync(dir)) {
    console.error(`Directory not found: ${dir}`);
    process.exit(1);
  }

  const files = fs.readdirSync(dir).filter((f: string) => f.endsWith('.json'));
  if (files.length === 0) {
    console.error('No attestation files found in ' + dir);
    process.exit(1);
  }

  const results: VerifyResult[] = [];
  let sessionFile: string | null = null;
  let sessionData: Record<string, unknown> | null = null;

  // First pass: verify all individual signatures
  for (const file of files) {
    const filePath = path.join(dir, file);
    const result = verifySingleFile(filePath, publicKey);
    results.push(result);

    if (result.type === 'session' && result.valid) {
      sessionFile = file;
      sessionData = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    }
  }

  // Second pass: if session exists, verify check attestation hashes match
  if (sessionData && sessionFile) {
    const expectedHashes = (sessionData.check_attestation_hashes as string[]) || [];
    const checkFiles = files.filter((f: string) => f.startsWith('check-') && f.endsWith('.json'));

    const actualHashes: string[] = [];
    for (const file of checkFiles) {
      const content = fs.readFileSync(path.join(dir, file), 'utf-8');
      actualHashes.push('sha256:' + sha256(content));
    }

    const sortedExpected = [...expectedHashes].sort();
    const sortedActual = [...actualHashes].sort();

    if (JSON.stringify(sortedExpected) !== JSON.stringify(sortedActual)) {
      results.push({
        file: sessionFile,
        type: 'session-integrity',
        valid: false,
        error: `Session references ${expectedHashes.length} check hashes but found ${actualHashes.length} check files`,
      });
    } else {
      results.push({
        file: sessionFile,
        type: 'session-integrity',
        valid: true,
      });
    }
  }

  // Report
  let allValid = true;
  for (const r of results) {
    const status = r.valid ? 'PASS' : 'FAIL';
    const detail = r.error ? ` — ${r.error}` : '';
    console.log(`  ${status}  ${r.type.padEnd(20)} ${r.file}${detail}`);
    if (!r.valid) allValid = false;
  }

  console.log('');
  if (allValid) {
    console.log(`VERIFIED: All ${results.length} checks passed in ${dir}`);
    process.exit(0);
  } else {
    const failures = results.filter((r) => !r.valid);
    console.error(`VERIFICATION_FAILED: ${failures.length} of ${results.length} checks failed`);
    process.exit(1);
  }
}

// ─── Main ───────────────────────────────────────────────────

const attestationDir = getFlag('attestation-dir');
const singleFile = getFlag('file');
const publicKeyPath = getFlag('public-key') || '';

if (!attestationDir && !singleFile) {
  console.error('Usage: hipaa-verify --attestation-dir DIR | --file PATH [--public-key PATH]');
  process.exit(1);
}

const publicKey = loadPublicKey(publicKeyPath || undefined);

if (attestationDir) {
  verifyDirectory(attestationDir, publicKey);
} else if (singleFile) {
  const result = verifySingleFile(singleFile, publicKey);
  if (result.valid) {
    console.log(`VERIFIED: ${result.type} attestation at ${singleFile}`);
    process.exit(0);
  } else {
    console.error(`VERIFICATION_FAILED: ${result.error} — ${singleFile}`);
    process.exit(1);
  }
}
