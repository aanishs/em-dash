#!/usr/bin/env bash
# hipaa-slug — output project slug and sanitized branch name
# Usage: source <(hipaa-slug)  → sets SLUG and BRANCH variables
# Or:    hipaa-slug           → prints SLUG=... and BRANCH=... lines
set -euo pipefail
_REMOTE=$(git remote get-url origin 2>/dev/null || echo "")
if [ -n "$_REMOTE" ]; then
  # Extract org/repo from remote URL, strip .git suffix
  SLUG=$(echo "$_REMOTE" | sed 's|\.git$||' | sed 's|.*[:/]\([^/]*/[^/]*\)$|\1|' | tr '/' '-')
  # Fallback to directory name if extraction failed
  [ -z "$SLUG" ] && SLUG=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null || basename "$(pwd)")
else
  # No git remote — use directory name
  SLUG=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null || basename "$(pwd)")
fi
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null | tr '/' '-')
echo "SLUG=$SLUG"
echo "BRANCH=$BRANCH"
