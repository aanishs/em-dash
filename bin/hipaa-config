#!/usr/bin/env bash
# hipaa-config — get/set configuration values
# Usage: hipaa-config get <key>
#        hipaa-config set <key> <value>
set -euo pipefail

CONFIG_FILE="$HOME/.em-dash/config.json"

ensure_config() {
  mkdir -p "$(dirname "$CONFIG_FILE")"
  [ -f "$CONFIG_FILE" ] || echo '{}' > "$CONFIG_FILE"
}

case "${1:-}" in
  get)
    ensure_config
    KEY="${2:?Usage: hipaa-config get <key>}"
    if command -v jq >/dev/null 2>&1; then
      jq -r ".\"$KEY\" // empty" "$CONFIG_FILE"
    else
      # Fallback: basic grep for simple key-value
      grep "\"$KEY\"" "$CONFIG_FILE" 2>/dev/null | sed 's/.*: *"\([^"]*\)".*/\1/' || true
    fi
    ;;
  set)
    ensure_config
    KEY="${2:?Usage: hipaa-config set <key> <value>}"
    VALUE="${3:?Usage: hipaa-config set <key> <value>}"
    if command -v jq >/dev/null 2>&1; then
      TMP=$(mktemp)
      jq --arg k "$KEY" --arg v "$VALUE" '.[$k] = $v' "$CONFIG_FILE" > "$TMP" && mv "$TMP" "$CONFIG_FILE"
    else
      echo "Error: jq is required for hipaa-config set" >&2
      exit 1
    fi
    ;;
  *)
    echo "Usage: hipaa-config get|set <key> [<value>]" >&2
    exit 1
    ;;
esac
