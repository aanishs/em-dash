#!/usr/bin/env bun
/**
 * Update em-dash dashboard data.
 *
 * Subcommands:
 *   checklist <id> <status> [note] [--gap desc] [--evidence file]
 *   finding add --title T --severity S --requirement R --source S [--description D]
 *   finding resolve --title T
 *   vendor add --name N --service S --baa-status B --risk-tier T [--contact C] [--baa-expiry D] [--notes N]
 *   vendor update --name N [--baa-status B] [--baa-expiry D] [--risk-tier T] [--notes N]
 *   risk add --description D --likelihood L --impact I --treatment T [--owner O] [--requirement R]
 *
 * Backward compat: if first arg looks like a checklist ID (starts with "164."), defaults to checklist subcommand.
 */

import * as fs from 'fs';

const DASHBOARD = '.em-dash/dashboard.json';
if (!fs.existsSync(DASHBOARD)) process.exit(0);

const args = process.argv.slice(2);
if (args.length === 0) {
  console.error('Usage: hipaa-dashboard-update <subcommand> [args]');
  process.exit(1);
}

// ─── Parse ──────────────────────────────────────────────────

function getFlag(name: string): string {
  const idx = args.indexOf(`--${name}`);
  if (idx === -1 || idx + 1 >= args.length) return '';
  return args[idx + 1];
}

function hasFlag(name: string): boolean {
  return args.includes(`--${name}`);
}

// ─── Framework Detection ────────────────────────────────────

const FRAMEWORK = getFlag('framework') || 'hipaa';

// ─── Read/Write ─────────────────────────────────────────────

function read(): any {
  const d = JSON.parse(fs.readFileSync(DASHBOARD, 'utf-8'));
  if (!d.version || d.version < 2) {
    d.version = 2;
    if (!d.risk_register) d.risk_register = [];
    if (!d.vendors) d.vendors = [];
  }
  if (!d.frameworks) d.frameworks = {};
  if (!d.frameworks[FRAMEWORK]) d.frameworks[FRAMEWORK] = { status: 'in-progress', skills: {}, checklist: [], findings: [], evidence_gaps: [] };
  if (!d.evidence) d.evidence = { files: [] };
  return d;
}

function write(d: any) {
  d.frameworks[FRAMEWORK].last_updated = new Date().toISOString();
  fs.writeFileSync(DASHBOARD, JSON.stringify(d, null, 2) + '\n');
}

// ─── Subcommands ────────────────────────────────────────────

function checklist() {
  // checklist <id> <status> [note] [--gap desc] [--evidence file]
  const subArgs = args.slice(args[0] === 'checklist' ? 1 : 0);
  const itemId = subArgs[0];
  const status = subArgs[1];
  if (!itemId || !status) { console.error('Usage: checklist <id> <status> [note]'); process.exit(1); }

  const gap = getFlag('gap');
  const evidence = getFlag('evidence');
  // Remaining positional arg is note
  let note = '';
  for (let i = 2; i < subArgs.length; i++) {
    if (subArgs[i].startsWith('--')) { i++; continue; }
    note = subArgs[i];
    break;
  }

  const d = read();
  const fw = d.frameworks[FRAMEWORK];

  const item = (fw.checklist || []).find((i: any) => i.id === itemId);
  if (item) {
    item.status = status;
    if (note) {
      if (!item.notes) {
        item.notes = note;
      } else if (!item.notes.includes(note)) {
        item.notes = item.notes + '; ' + note;
      }
    }
    if (evidence) {
      if (!item.evidence) item.evidence = [];
      if (!item.evidence.includes(evidence)) item.evidence.push(evidence);
    }
  }

  if (!fw.evidence_gaps) fw.evidence_gaps = [];
  fw.evidence_gaps = fw.evidence_gaps.filter((g: any) => g.requirement !== itemId);
  if (status === 'pending' && gap) {
    fw.evidence_gaps.push({ requirement: itemId, description: gap, suggested_type: 'other' });
  }

  write(d);
}

function findingAdd() {
  const title = getFlag('title');
  const severity = getFlag('severity') || 'medium';
  const requirement = getFlag('requirement') || '';
  const source = getFlag('source') || 'manual';
  const description = getFlag('description') || '';

  if (!title) { console.error('Usage: finding add --title T --severity S'); process.exit(1); }

  const d = read();
  const fw = d.frameworks[FRAMEWORK];
  if (!fw.findings) fw.findings = [];

  // Don't duplicate by title
  if (fw.findings.some((f: any) => f.title === title && f.status !== 'resolved')) {
    write(d); // still update timestamp
    return;
  }

  fw.findings.push({
    id: `F-${Date.now()}`,
    title,
    description,
    severity,
    status: 'open',
    requirement,
    source,
    discovered_at: new Date().toISOString(),
    resolved_at: null,
  });

  // Recalculate skill finding count to stay in sync
  if (source && fw.skills) {
    const skillKey = source.replace(/^hipaa-/, '');
    if (fw.skills[skillKey]) {
      fw.skills[skillKey].findings = fw.findings.filter(
        (f: any) => f.source === source && f.status !== 'resolved'
      ).length;
    }
  }

  write(d);
}

function findingResolve() {
  const title = getFlag('title');
  if (!title) { console.error('Usage: finding resolve --title T'); process.exit(1); }

  const d = read();
  const fw = d.frameworks[FRAMEWORK];
  let resolvedSource = '';
  for (const f of (fw.findings || [])) {
    if (f.title === title && f.status !== 'resolved') {
      f.status = 'resolved';
      f.resolved_at = new Date().toISOString();
      resolvedSource = f.source || '';
    }
  }

  // Recalculate skill finding count after resolution
  if (resolvedSource && fw.skills) {
    const skillKey = resolvedSource.replace(/^hipaa-/, '');
    if (fw.skills[skillKey]) {
      fw.skills[skillKey].findings = fw.findings.filter(
        (f: any) => f.source === resolvedSource && f.status !== 'resolved'
      ).length;
    }
  }

  write(d);
}

function vendorAdd() {
  const name = getFlag('name');
  const service = getFlag('service') || '';
  const baaStatus = getFlag('baa-status') || 'none';
  const riskTier = getFlag('risk-tier') || 'medium';
  const contact = getFlag('contact') || '';
  const baaExpiry = getFlag('baa-expiry') || null;
  const notes = getFlag('notes') || '';

  if (!name) { console.error('Usage: vendor add --name N'); process.exit(1); }

  const d = read();
  if (!d.vendors) d.vendors = [];

  // Don't duplicate by name
  if (d.vendors.some((v: any) => v.name.toLowerCase() === name.toLowerCase())) {
    // Update existing instead
    const v = d.vendors.find((v: any) => v.name.toLowerCase() === name.toLowerCase());
    if (service) v.service = service;
    if (baaStatus !== 'none' || !v.baa_status) v.baa_status = baaStatus;
    if (riskTier) v.risk_tier = riskTier;
    if (contact) v.contact = contact;
    if (baaExpiry) v.baa_expiry = baaExpiry;
    if (notes) v.notes = notes;
    write(d);
    return;
  }

  d.vendors.push({
    id: `V-${Date.now()}`,
    name,
    service,
    baa_status: baaStatus,
    baa_expiry: baaExpiry,
    risk_tier: riskTier,
    contact,
    notes,
    created_at: new Date().toISOString(),
  });

  write(d);
}

function vendorUpdate() {
  const name = getFlag('name');
  if (!name) { console.error('Usage: vendor update --name N [--baa-status B]'); process.exit(1); }

  const d = read();
  const v = (d.vendors || []).find((v: any) => v.name.toLowerCase() === name.toLowerCase());
  if (!v) { console.error(`Vendor "${name}" not found`); process.exit(1); }

  const baaStatus = getFlag('baa-status');
  const baaExpiry = getFlag('baa-expiry');
  const riskTier = getFlag('risk-tier');
  const notes = getFlag('notes');

  if (baaStatus) v.baa_status = baaStatus;
  if (baaExpiry) v.baa_expiry = baaExpiry;
  if (riskTier) v.risk_tier = riskTier;
  if (notes) v.notes = notes;

  write(d);
}

function riskAdd() {
  const description = getFlag('description');
  const likelihood = parseInt(getFlag('likelihood') || '3', 10);
  const impact = parseInt(getFlag('impact') || '3', 10);
  const treatment = getFlag('treatment') || 'mitigate';
  const owner = getFlag('owner') || '';
  const requirement = getFlag('requirement') || '';

  if (!description) { console.error('Usage: risk add --description D --likelihood L --impact I'); process.exit(1); }

  const d = read();
  if (!d.risk_register) d.risk_register = [];

  d.risk_register.push({
    id: `R-${Date.now()}`,
    description,
    likelihood,
    impact,
    score: likelihood * impact,
    treatment,
    owner,
    status: 'open',
    requirement_ids: requirement ? requirement.split(',').map((s: string) => s.trim()) : [],
    created_at: new Date().toISOString(),
    updated_at: new Date().toISOString(),
  });

  write(d);
}

// ─── Router ─────────────────────────────────────────────────

const cmd = args[0];

// Backward compat: bare checklist ID (starts with "164.")
if (cmd.startsWith('164.')) {
  checklist();
} else if (cmd === 'checklist') {
  checklist();
} else if (cmd === 'finding') {
  const action = args[1];
  if (action === 'add') findingAdd();
  else if (action === 'resolve') findingResolve();
  else { console.error('Usage: finding <add|resolve>'); process.exit(1); }
} else if (cmd === 'vendor') {
  const action = args[1];
  if (action === 'add') vendorAdd();
  else if (action === 'update') vendorUpdate();
  else { console.error('Usage: vendor <add|update>'); process.exit(1); }
} else if (cmd === 'risk') {
  const action = args[1];
  if (action === 'add') riskAdd();
  else { console.error('Usage: risk add --description D ...'); process.exit(1); }
} else if (cmd === 'sync') {
  const d = read();
  const fw = d.frameworks[FRAMEWORK];
  if (fw.skills) {
    for (const key of Object.keys(fw.skills)) {
      if (fw.skills[key]) {
        fw.skills[key].findings = (fw.findings || []).filter(
          (f: any) => f.source === key && f.status !== 'resolved'
        ).length;
      }
    }
  }
  write(d);
  const open = (fw.findings || []).filter((f: any) => f.status !== 'resolved').length;
  console.log(`Synced: ${open} open findings`);
} else {
  console.error(`Unknown subcommand: ${cmd}`);
  process.exit(1);
}
