    { id: '1.12', section: 'IAM', description: 'Ensure credentials unused for 45+ days are disabled' },
    { id: '1.14', section: 'IAM', description: 'Ensure access keys are rotated within 90 days' },
    { id: '1.16', section: 'IAM', description: 'Ensure IAM policies are attached only to groups or roles' },
    { id: '1.17', section: 'IAM', description: 'Ensure a support role has been created for AWS Support' },
    { id: '1.22', section: 'IAM', description: 'Ensure IAM users are managed centrally via identity federation' },
    { id: '2.1.1', section: 'Storage', description: 'Ensure S3 bucket encryption is enabled' },
    { id: '2.1.2', section: 'Storage', description: 'Ensure S3 bucket policy denies HTTP requests' },
    { id: '2.1.4', section: 'Storage', description: 'Ensure S3 public access is blocked at account level' },
    { id: '2.3.1', section: 'Storage', description: 'Ensure RDS instances have encryption at rest enabled' },
    { id: '2.3.2', section: 'Storage', description: 'Ensure RDS instances have auto minor version upgrade enabled' },
    { id: '2.3.3', section: 'Storage', description: 'Ensure RDS instances are not publicly accessible' },
    { id: '2.4.1', section: 'Storage', description: 'Ensure EBS volume encryption is enabled by default' },
    { id: '3.1', section: 'Logging', description: 'Ensure CloudTrail is enabled in all regions' },
    { id: '3.2', section: 'Logging', description: 'Ensure CloudTrail log file validation is enabled' },
    { id: '3.3', section: 'Logging', description: 'Ensure CloudTrail S3 bucket is not publicly accessible' },
    { id: '3.4', section: 'Logging', description: 'Ensure CloudTrail trails are integrated with CloudWatch Logs' },
    { id: '3.5', section: 'Logging', description: 'Ensure AWS Config is enabled in all regions' },
    { id: '3.6', section: 'Logging', description: 'Ensure S3 bucket access logging is enabled on CloudTrail bucket' },
    { id: '3.7', section: 'Logging', description: 'Ensure CloudTrail logs are encrypted with KMS CMK' },
    { id: '4.1', section: 'Monitoring', description: 'Ensure unauthorized API calls alarm is configured' },
    { id: '4.3', section: 'Monitoring', description: 'Ensure root account usage alarm is configured' },
    { id: '4.4', section: 'Monitoring', description: 'Ensure IAM policy changes alarm is configured' },
    { id: '4.5', section: 'Monitoring', description: 'Ensure CloudTrail config changes alarm is configured' },
    { id: '4.6', section: 'Monitoring', description: 'Ensure console auth failures alarm is configured' },
    { id: '4.12', section: 'Monitoring', description: 'Ensure network gateway changes alarm is configured' },
    { id: '4.14', section: 'Monitoring', description: 'Ensure VPC changes alarm is configured' },
    { id: '5.1', section: 'Networking', description: 'Ensure no network ACLs allow 0.0.0.0/0 ingress to admin ports' },
    { id: '5.2', section: 'Networking', description: 'Ensure no security groups allow 0.0.0.0/0 ingress to admin ports' },
    { id: '5.3', section: 'Networking', description: 'Ensure default security group restricts all traffic' },
    { id: '5.4', section: 'Networking', description: 'Ensure VPC flow logging is enabled in all VPCs' },
  ];

  // Load tool-bindings to find which CIS benchmark IDs em-dash covers
  const bindingsPath = path.join(NIST_DIR, 'tool-bindings.json');
  const bindings = JSON.parse(fs.readFileSync(bindingsPath, 'utf-8'));

  const coveredIds = new Set<string>();
  for (const binding of Object.values(bindings.bindings) as any[]) {
    for (const ref of binding.cis_benchmark || []) coveredIds.add(ref);
  }

  console.log('CIS AWS Foundations Benchmark v3.0 — Level 1 Coverage Report');
  console.log('═══════════════════════════════════════════════════════════');
  console.log(`em-dash covers ${coveredIds.size} of ${CIS_AWS_LEVEL1.length} Level 1 automated recommendations\n`);

  const covered: typeof CIS_AWS_LEVEL1 = [];
  const gaps: typeof CIS_AWS_LEVEL1 = [];

  for (const rec of CIS_AWS_LEVEL1) {
    if (coveredIds.has(rec.id)) covered.push(rec);
    else gaps.push(rec);
  }

  if (covered.length > 0) {
    console.log(`COVERED (${covered.length}):`);
    for (const r of covered) console.log(`  ✓ ${r.id.padEnd(8)} ${r.section.padEnd(12)} ${r.description}`);
    console.log();
  }

  if (gaps.length > 0) {
    console.log(`GAPS (${gaps.length}):`);
    for (const r of gaps) console.log(`  ✗ ${r.id.padEnd(8)} ${r.section.padEnd(12)} ${r.description}`);
    console.log();
  }

  const pct = Math.round((covered.length / CIS_AWS_LEVEL1.length) * 100);
  console.log(`Coverage: ${pct}% (${covered.length}/${CIS_AWS_LEVEL1.length})`);
  if (gaps.length > 0) {
    console.log(`\nTo improve: add cis_benchmark IDs to controls in nist/tool-bindings.json`);
  }
}

// ─── HIPAA Sections (reverse map) ────────────────────────────

/**
 * Reverse-maps a NIST control ID to HIPAA CFR sections + category.
 *
 * CFR prefix → HIPAA category:
 *   164.308 → Administrative Safeguards
 *   164.310 → Physical Safeguards
 *   164.312 → Technical Safeguards
 *   164.314 → Organizational Requirements
 *   164.316 → Policies & Procedures (Documentation)
 */
function hipaaSections() {
  const controlId = args[1];
  if (!controlId) { console.error('Usage: comply-db hipaa-sections <oscal_id>'); process.exit(1); }

  const filterPath = path.join(NIST_DIR, 'hipaa-filter.json');
  if (!fs.existsSync(filterPath)) { console.error('HIPAA filter not found'); process.exit(1); }
  const filter = JSON.parse(fs.readFileSync(filterPath, 'utf-8'));

  const CFR_CATEGORIES: Record<string, string> = {
    '164.308': 'Administrative Safeguards',
    '164.310': 'Physical Safeguards',
    '164.312': 'Technical Safeguards',
    '164.314': 'Organizational Requirements',
    '164.316': 'Policies & Procedures',
  };

  const cfrRefs: string[] = [];
  const categories = new Set<string>();
  const upperControlId = controlId.toUpperCase();

  for (const [spec, controls] of Object.entries(filter.mapping)) {
    if ((controls as string[]).some(c => c.toUpperCase() === upperControlId)) {
      cfrRefs.push(spec);
      // Derive category from CFR prefix (e.g., "164.312(a)(1)" → "164.312")
      const prefix = spec.match(/^(\d+\.\d+)/)?.[1] || '';
      const cat = CFR_CATEGORIES[prefix];
      if (cat) categories.add(cat);
    }
  }

  const result = {
    control_id: controlId,
    cfr_refs: cfrRefs,
    categories: Array.from(categories),
    primary_category: Array.from(categories)[0] || 'Unknown',
  };
  console.log(JSON.stringify(result));
}

// ─── Audit Snapshots ────────────────────────────────────────

function auditSnapshot() {
  const sub = args[1];

  if (sub === 'create') {
    const auditType = getFlag('type') || 'ocr-desk';
    const validTypes = ['ocr-desk', 'customer-questionnaire', 'comprehensive'];
    if (!validTypes.includes(auditType)) {
      console.error(`Invalid audit type: ${auditType}. Valid: ${validTypes.join(', ')}`);
      process.exit(1);
    }

    const db = openDb();
    migrateSchema(db);
    const result = db.prepare('INSERT INTO audit_snapshots (audit_type) VALUES (?)').run(auditType);
    db.close();
    console.log(JSON.stringify({ snapshot_id: result.lastInsertRowid, audit_type: auditType, current_phase: 1 }));
    return;
  }

  if (sub === 'update') {
    const id = getFlag('id');
    if (!id) { console.error('Usage: comply-db audit-snapshot update --id <N> [--phase <N>] [--grade <G>] [--completed]'); process.exit(1); }

    const db = openDb();
    const phase = getFlag('phase');
    const grade = getFlag('grade');
    const completed = args.includes('--completed');

    if (phase) db.prepare('UPDATE audit_snapshots SET current_phase = ? WHERE id = ?').run(Number(phase), Number(id));
    if (grade) db.prepare('UPDATE audit_snapshots SET grade = ? WHERE id = ?').run(grade, Number(id));
    if (completed) db.prepare('UPDATE audit_snapshots SET completed_at = datetime(\'now\') WHERE id = ?').run(Number(id));
    db.close();
    console.log(JSON.stringify({ updated: Number(id) }));
    return;
  }

  if (sub === 'list') {
    const db = openDb();
    const snapshots = db.prepare('SELECT * FROM audit_snapshots ORDER BY created_at DESC').all();
    db.close();
    console.log(JSON.stringify(snapshots));
    return;
  }

  if (sub === 'get') {
    const id = args[2] || getFlag('id');
    if (!id) { console.error('Usage: comply-db audit-snapshot get <id>'); process.exit(1); }
    const db = openDb();
    const snapshot = db.prepare('SELECT * FROM audit_snapshots WHERE id = ?').get(Number(id));
    const findings = db.prepare('SELECT * FROM audit_findings WHERE snapshot_id = ? ORDER BY finding_number').all(Number(id));
    db.close();
    if (!snapshot) { console.error(`Snapshot ${id} not found`); process.exit(1); }
    console.log(JSON.stringify({ ...(snapshot as any), findings }));
    return;
  }

  if (sub === 'in-progress') {
    const db = openDb();
    const snapshot = db.prepare('SELECT * FROM audit_snapshots WHERE completed_at IS NULL ORDER BY created_at DESC LIMIT 1').get();
    db.close();
    if (!snapshot) {
      console.log(JSON.stringify({ found: false }));
    } else {
      console.log(JSON.stringify({ found: true, ...(snapshot as any) }));
    }
    return;
  }

  console.error('Usage: comply-db audit-snapshot <create|update|list|get|in-progress>');
  process.exit(1);
}

// ─── Audit Findings (record) ────────────────────────────────

function recordAuditFinding() {
  const snapshotId = getFlag('snapshot-id');
  const controlId = getFlag('control');
  const severity = getFlag('severity');
  const description = getFlag('description');
  const checkId = getFlag('check-id') || '';
  const hipaaSection = getFlag('hipaa-section') || '';
  const cfrRef = getFlag('cfr-ref') || '';

  if (!snapshotId || !controlId || !severity || !description) {
    console.error('Usage: comply-db record-finding --snapshot-id <N> --control <id> --severity <Critical|Major|Minor|Observation> --description "..." [--check-id X] [--hipaa-section X] [--cfr-ref X]');
    process.exit(1);
  }

  const validSeverities = ['Critical', 'Major', 'Minor', 'Observation'];
  if (!validSeverities.includes(severity)) {
    console.error(`Invalid severity: ${severity}. Valid: ${validSeverities.join(', ')}`);
    process.exit(1);
  }

  const db = openDb();
  // Get next finding number for this snapshot
  const max = db.prepare('SELECT MAX(finding_number) as maxn FROM audit_findings WHERE snapshot_id = ?').get(Number(snapshotId)) as any;
  const nextNum = (max?.maxn || 0) + 1;

  db.prepare('INSERT INTO audit_findings (snapshot_id, finding_number, control_id, check_id, hipaa_section, severity, description, cfr_reference) VALUES (?, ?, ?, ?, ?, ?, ?, ?)').run(
    Number(snapshotId), nextNum, controlId, checkId, hipaaSection, severity, description, cfrRef,
  );
  db.close();
  console.log(JSON.stringify({ finding_number: nextNum, snapshot_id: Number(snapshotId), control_id: controlId, severity }));
}

// ─── Audit Finding Response ─────────────────────────────────

function recordFindingResponse() {
  const snapshotId = getFlag('snapshot-id');
  const findingNum = getFlag('finding');
  const response = getFlag('response');
  const responseText = getFlag('response-text') || '';

  if (!snapshotId || !findingNum || !response) {
    console.error('Usage: comply-db record-response --snapshot-id <N> --finding <num> --response <accepted|compensating|disputed> [--response-text "..."]');
    process.exit(1);
  }

  const validResponses = ['accepted', 'compensating', 'disputed'];
  if (!validResponses.includes(response)) {
    console.error(`Invalid response: ${response}. Valid: ${validResponses.join(', ')}`);
    process.exit(1);
  }

  const db = openDb();
  const result = db.prepare('UPDATE audit_findings SET entity_response = ?, entity_response_text = ? WHERE snapshot_id = ? AND finding_number = ?').run(
    response, responseText, Number(snapshotId), Number(findingNum),
  );
  db.close();

  if (result.changes === 0) {
    console.error(`Finding #${findingNum} not found in snapshot ${snapshotId}`);
    process.exit(1);
  }
  console.log(JSON.stringify({ updated: true, snapshot_id: Number(snapshotId), finding_number: Number(findingNum), response }));
}

// ─── Audit Diff ─────────────────────────────────────────────

function auditDiff() {
  const id1 = getFlag('id1');
  const id2 = getFlag('id2');
  if (!id1 || !id2) { console.error('Usage: comply-db audit-diff --id1 <N> --id2 <N>'); process.exit(1); }

  const db = openDb();
  const snap1 = db.prepare('SELECT * FROM audit_snapshots WHERE id = ?').get(Number(id1)) as any;
  const snap2 = db.prepare('SELECT * FROM audit_snapshots WHERE id = ?').get(Number(id2)) as any;
  if (!snap1) { console.error(`Snapshot ${id1} not found`); db.close(); process.exit(1); }
  if (!snap2) { console.error(`Snapshot ${id2} not found`); db.close(); process.exit(1); }

  if (snap1.audit_type !== snap2.audit_type) {
    console.error(`WARNING: Comparing different audit types (${snap1.audit_type} vs ${snap2.audit_type})`);
  }

  const findings1 = db.prepare('SELECT * FROM audit_findings WHERE snapshot_id = ?').all(Number(id1)) as any[];
  const findings2 = db.prepare('SELECT * FROM audit_findings WHERE snapshot_id = ?').all(Number(id2)) as any[];
  db.close();

  // Build composite keys for matching: control_id + check_id + hipaa_section
  const key = (f: any) => `${f.control_id}|${f.check_id || ''}|${f.hipaa_section || ''}`;
  const map1 = new Map(findings1.map(f => [key(f), f]));
  const map2 = new Map(findings2.map(f => [key(f), f]));

  const resolved: any[] = [];   // in snap1 but not snap2
  const newFindings: any[] = []; // in snap2 but not snap1
  const changedSeverity: any[] = [];
  const unchanged: any[] = [];

  for (const [k, f1] of map1) {
    const f2 = map2.get(k);
    if (!f2) {
      resolved.push(f1);
    } else if (f1.severity !== f2.severity) {
      changedSeverity.push({ control_id: f1.control_id, old_severity: f1.severity, new_severity: f2.severity });
    } else {
      unchanged.push(f1);
    }
  }
  for (const [k, f2] of map2) {
    if (!map1.has(k)) newFindings.push(f2);
  }

  const result = {
    snapshot_old: { id: Number(id1), grade: snap1.grade, audit_type: snap1.audit_type, created_at: snap1.created_at },
    snapshot_new: { id: Number(id2), grade: snap2.grade, audit_type: snap2.audit_type, created_at: snap2.created_at },
    resolved: resolved.length,
    new_findings: newFindings.length,
    changed_severity: changedSeverity.length,
    unchanged: unchanged.length,
    grade_delta: `${snap1.grade || '?'} → ${snap2.grade || '?'}`,
    details: { resolved, new_findings: newFindings, changed_severity: changedSeverity },
  };
  console.log(JSON.stringify(result));
}

// ─── Journey ───────────────────────────────────────────────

const JOURNEY_MILESTONES = [
  { id: 1, name: 'Framework Advisor' },
  { id: 2, name: 'Assessment & Scan' },
  { id: 3, name: 'Policy Generator' },
  { id: 4, name: 'PR Gate Setup' },
  { id: 5, name: 'Trust Page' },
  { id: 6, name: 'Deal Rescue' },
];

function journey() {
  const sub = args[1];
  if (!sub || !['init', 'status', 'skip', 'complete'].includes(sub)) {
    console.error('Usage: comply-db journey <init|status|skip|complete> [--milestone N]');
    process.exit(1);
  }

  const db = openDb();
  migrateSchema(db);

  if (sub === 'init') {
    const existing = db.prepare('SELECT COUNT(*) as n FROM journey_milestones').get() as any;
    if (existing.n > 0) {
      db.close();
      console.log(JSON.stringify({ action: 'already_initialized', milestones: existing.n }));
      return;
    }
    const insert = db.prepare('INSERT INTO journey_milestones (milestone_id, name, status) VALUES (?, ?, ?)');
    const tx = db.transaction(() => {
      for (const m of JOURNEY_MILESTONES) {
        insert.run(m.id, m.name, m.id === 1 ? 'AVAILABLE' : 'LOCKED');
      }
    });
    tx();
    db.close();
    console.log(JSON.stringify({ action: 'initialized', milestones: JOURNEY_MILESTONES.length }));
    return;
  }

  if (sub === 'status') {
    const milestones = db.prepare('SELECT * FROM journey_milestones ORDER BY milestone_id').all();
    if (milestones.length === 0) {
      db.close();
      console.log(JSON.stringify({ initialized: false, milestones: [] }));
      return;
    }
    const current = (milestones as any[]).find(m => m.status !== 'COMPLETE' && m.status !== 'SKIPPED') || null;
    console.log(JSON.stringify({
      initialized: true,
      current_milestone: current ? { id: current.milestone_id, name: current.name, status: current.status } : null,
      milestones: (milestones as any[]).map(m => ({
        id: m.milestone_id,
        name: m.name,
        status: m.status,
        needs_revalidation: !!m.needs_revalidation,
      })),
      complete: (milestones as any[]).every(m => m.status === 'COMPLETE' || m.status === 'SKIPPED'),
    }));
    db.close();
    return;
  }

  if (sub === 'skip' || sub === 'complete') {
    const milestoneId = Number(getFlag('milestone'));
    if (!milestoneId || milestoneId < 1 || milestoneId > JOURNEY_MILESTONES.length) {
      console.error(`Usage: comply-db journey ${sub} --milestone <1-${JOURNEY_MILESTONES.length}>`);
      process.exit(1);
    }
    const label = sub === 'skip' ? 'SKIPPED' : 'COMPLETE';
    const now = new Date().toISOString();
    db.prepare('UPDATE journey_milestones SET status = ?, completed_at = ? WHERE milestone_id = ?')
      .run(label, now, milestoneId);

    // Unlock next milestone if it exists and is LOCKED
    const nextId = milestoneId + 1;
    if (nextId <= JOURNEY_MILESTONES.length) {
      const next = db.prepare('SELECT status FROM journey_milestones WHERE milestone_id = ?').get(nextId) as any;
      if (next && next.status === 'LOCKED') {
        db.prepare('UPDATE journey_milestones SET status = ? WHERE milestone_id = ?').run('AVAILABLE', nextId);
      }
    }

    db.close();
    console.log(JSON.stringify({
      action: sub,
      milestone_id: milestoneId,
      status: label,
      next_unlocked: nextId <= JOURNEY_MILESTONES.length ? nextId : null,
    }));
  }
}

// ─── User Config ───────────────────────────────────────────

function getUserConfigPath(): string {
  return path.join(process.env.HOME ?? '', '.em-dash', 'config.json');
}

function readUserConfig(): Record<string, any> {
  const p = getUserConfigPath();
  if (!fs.existsSync(p)) return {};
  try {
    return JSON.parse(fs.readFileSync(p, 'utf-8'));
  } catch {
    return {};
  }
}

function writeUserConfig(config: Record<string, any>) {
  const p = getUserConfigPath();
  const dir = path.dirname(p);
  if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
  fs.writeFileSync(p, JSON.stringify(config, null, 2) + '\n');
}

function config() {
  const sub = args[1];
  const key = args[2];

  if (sub === 'get') {
    if (!key) {
      // Return all config
      console.log(JSON.stringify(readUserConfig()));
      return;
    }
    const cfg = readUserConfig();
    console.log(cfg[key] ?? '');
    return;
  }

  if (sub === 'set') {
    const value = args[3];
    if (!key || value === undefined) {
      console.error('Usage: comply-db config set <key> <value>');
      process.exit(1);
    }
    const validKeys: Record<string, string[]> = {
      persona: ['founder', 'engineer', 'audit'],
      explain: ['always', 'on-demand', 'off'],
      auto_sign: ['true', 'false'],
    };
    if (!Object.keys(validKeys).includes(key)) {
      console.error(`Unknown config key: ${key}. Known keys: ${Object.keys(validKeys).join(', ')}`);
      process.exit(1);
    }
    if (!validKeys[key].includes(value)) {
      console.error(`Invalid value for ${key}. Must be one of: ${validKeys[key].join(', ')}`);
      process.exit(1);
    }
    const cfg = readUserConfig();
    cfg[key] = value;
    writeUserConfig(cfg);
    console.log(JSON.stringify({ action: 'set', key, value }));
    return;
  }

  console.error('Usage: comply-db config <get|set> <key> [value]');
  process.exit(1);
}

// ─── Router ─────────────────────────────────────────────────

switch (subcommand) {
  case 'init': init(); break;
  case 'status': status(); break;
  case 'control': controlDetail(); break;
  case 'update-scan': updateScan(); break;
  case 'summary': summary(); break;
  case 'sign': signControl(); break;
  case 'validate-tools': validateTools(); break;
  case 'cross-framework': crossFramework(); break;
  case 'frameworks': frameworks(); break;
  case 'cis-coverage': cisCoverage(); break;
  case 'hipaa-sections': hipaaSections(); break;
  case 'audit-snapshot': auditSnapshot(); break;
  case 'record-finding': recordAuditFinding(); break;
  case 'record-response': recordFindingResponse(); break;
  case 'audit-diff': auditDiff(); break;
  case 'journey': journey(); break;
  case 'config': config(); break;
  case 'query': rawQuery(); break;
  default:
    console.error('Usage: comply-db <init|status|control|update-scan|summary|cross-framework|frameworks|hipaa-sections|audit-snapshot|record-finding|record-response|audit-diff|cis-coverage|journey|config|query>');
    if (subcommand) console.error(`Unknown: ${subcommand}`);
    process.exit(1);
}
