#!/usr/bin/env bun
/**
 * comply-db — SQLite compliance database manager.
 *
 * The single evidence store for all compliance data. Replaces:
 * control-state.json, dashboard.json evidence, attestations/*.json
 *
 * Subcommands:
 *   init                    Create DB + import controls from NIST catalog
 *   status                  Show compliance progress per control
 *   control <oscal_id>      Show full detail for one control (NIST prose + evidence)
 *   update-scan <id> <result>  Record scan result [--severity X] [--resource X] [--scan-id X]
 *   update-interview <id>      Record interview completion (planned — WP-1.1)
 *   sign <id>                  Record user signature
 *   summary                    Overall compliance score
 *   cross-framework            Show cross-framework compliance matrix
 *   hipaa-sections <id>        Reverse-map: NIST control → HIPAA CFR sections + category
 *   audit-snapshot <create|update|list|get>  Manage audit snapshots
 *   audit-diff --id1 <N> --id2 <N>          Compare two audit snapshots
 *   journey <init|status|skip|complete>     Manage compliance journey milestones
 *   config <get|set> <key> [value]          User preferences (~/.em-dash/config.json)
 *   query <sql>                Run raw SQL (for debugging)
 */

import { Database } from 'bun:sqlite';
import * as fs from 'fs';
import * as path from 'path';

const args = process.argv.slice(2);
const subcommand = args[0];
const NIST_DIR = path.join(import.meta.dir, '..', 'nist');

// ─── Framework detection ────────────────────────────────────

function getFlag(name: string): string {
  const idx = args.indexOf(`--${name}`);
  if (idx === -1 || idx + 1 >= args.length) return '';
  return args[idx + 1];
}

const FRAMEWORK = getFlag('framework') || 'hipaa';

// Validate framework name to prevent path traversal
if (!/^[a-z0-9-]+$/.test(FRAMEWORK)) {
  console.error(`Invalid framework name: ${FRAMEWORK}`);
  process.exit(1);
}

function getFilterPath(): string {
  return path.join(NIST_DIR, `${FRAMEWORK}-filter.json`);
}

// ─── Helpers ────────────────────────────────────────────────

function getSlug(): string {
  try {
    const proc = Bun.spawnSync([path.join(import.meta.dir, 'comply-slug')], { stdout: 'pipe', stderr: 'pipe' });
    const match = new TextDecoder().decode(proc.stdout).match(/SLUG=(\S+)/);
    if (match) return match[1];
  } catch {}
  return path.basename(process.cwd());
}

function getDbPath(): string {
  return path.join(process.env.HOME ?? '', '.em-dash', 'projects', getSlug(), 'compliance.db');
}

function ensureDbDir(): void {
  const dir = path.dirname(getDbPath());
  if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
}

function openDb(): InstanceType<typeof Database> {
  ensureDbDir();
  return new Database(getDbPath());
}

function loadNistCatalog(): any {
  const p = path.join(NIST_DIR, 'NIST_SP-800-53_rev5_catalog.json');
  if (!fs.existsSync(p)) { console.error('NIST catalog not found at ' + p); process.exit(1); }
  return JSON.parse(fs.readFileSync(p, 'utf-8'));
}

function loadFilter(): any {
  const p = getFilterPath();
  if (!fs.existsSync(p)) { console.error(`Filter not found: ${p}\nAvailable: ${fs.readdirSync(NIST_DIR).filter(f => f.endsWith('-filter.json')).join(', ')}`); process.exit(1); }
  return JSON.parse(fs.readFileSync(p, 'utf-8'));
}

/** Find a control object in the NIST catalog by ID. Returns the control and its family group. */
function findControlInCatalog(catalog: any, controlId: string): { control: any; family: string } | null {
  const id = controlId.toLowerCase();
  for (const group of catalog.catalog.groups) {
    for (const ctrl of group.controls || []) {
      if (ctrl.id === id) return { control: ctrl, family: group.title };
      for (const enh of ctrl.controls || []) {
        if (enh.id === id) return { control: enh, family: group.title };
      }
    }
  }
  return null;
}

/** Extract control prose from NIST catalog */
function extractControlProse(catalog: any, controlId: string): { prose: string; assess: string; title: string; family: string } {
  const found = findControlInCatalog(catalog, controlId);
  if (!found) return { prose: '', assess: '', title: controlId, family: 'Unknown' };
  const { control, family } = found;
  const prose = extractParts(control.parts?.filter((p: any) => p.name === 'statement') || []);
  const assess = extractParts(control.parts?.filter((p: any) => p.name === 'assessment') || []);
  return { prose, assess, title: control.title, family };
}

function extractParts(parts: any[]): string {
  let result = '';
  for (const part of parts) {
    if (part.prose) result += part.prose + '\n';
    if (part.parts) result += extractParts(part.parts);
  }
  return result.trim();
}

// ─── Explain Helpers ────────────────────────────────────────

const PLAIN_ENGLISH_PATH = path.join(NIST_DIR, 'plain-english.json');
const TOOL_BINDINGS_PATH = path.join(NIST_DIR, 'tool-bindings.json');
const HIPAA_JSON_PATH = path.join(import.meta.dir, '..', 'frameworks', 'hipaa.json');

/** Known tool keys in tool-bindings.json (everything else is metadata) */
const TOOL_KEYS = ['emdash', 'prowler', 'checkov', 'trivy', 'lynis'];

function loadPlainEnglish(controlId: string): { plain_english: string; why_it_matters: string; nist_name: string } | null {
  try {
    if (!fs.existsSync(PLAIN_ENGLISH_PATH)) return null;
    const data = JSON.parse(fs.readFileSync(PLAIN_ENGLISH_PATH, 'utf-8'));
    return data[controlId] || null;
  } catch { return null; }
}

function extractGuidance(catalog: any, controlId: string): string {
  const found = findControlInCatalog(catalog, controlId);
  if (!found) return '';
  const guidancePart = found.control.parts?.find((p: any) => p.name === 'guidance');
  return guidancePart?.prose || '';
}

/** Build an index of controlId → title from the full NIST catalog */
function buildCatalogIndex(catalog: any): Record<string, string> {
  const index: Record<string, string> = {};
  for (const group of catalog.catalog.groups) {
    for (const ctrl of group.controls || []) {
      index[ctrl.id.toUpperCase()] = ctrl.title;
      for (const enh of ctrl.controls || []) {
        index[enh.id.toUpperCase()] = enh.title || ctrl.title;
      }
    }
  }
  return index;
}

function extractRelatedControls(catalog: any, controlId: string, catalogIndex: Record<string, string>): { id: string; title: string }[] {
  const found = findControlInCatalog(catalog, controlId);
  if (!found) return [];
  return (found.control.links || [])
    .filter((l: any) => l.rel === 'related')
    .map((l: any) => {
      const refId = l.href.replace('#', '').toUpperCase();
      return { id: refId, title: catalogIndex[refId] || refId };
    });
}

function resolveFromCFR(cfrSection: string): string[] {
  try {
    const filterPath = path.join(NIST_DIR, 'hipaa-filter.json');
    if (!fs.existsSync(filterPath)) return [];
    const filter = JSON.parse(fs.readFileSync(filterPath, 'utf-8'));
    const controls = filter.mapping[cfrSection];
    return Array.isArray(controls) ? controls : [];
  } catch { return []; }
}

function normalizeVerification(controlId: string): { automated: boolean; tools: string[]; checks: string[]; interview_only: boolean } | null {
  try {
    if (!fs.existsSync(TOOL_BINDINGS_PATH)) return null;
    const bindings = JSON.parse(fs.readFileSync(TOOL_BINDINGS_PATH, 'utf-8'));
    const binding = bindings.bindings[controlId];
    if (!binding) return null;

    const tools: string[] = [];
    const checks: string[] = [];
    for (const key of TOOL_KEYS) {
      const arr = binding[key];
      if (Array.isArray(arr) && arr.length > 0) {
        tools.push(key);
        checks.push(...arr);
      }
    }

    return {
      automated: tools.length > 0,
      tools,
      checks,
      interview_only: binding.interview_only === true,
    };
  } catch { return null; }
}

function getHipaaName(cfrSections: string[]): string | null {
  try {
    if (!fs.existsSync(HIPAA_JSON_PATH)) return null;
    const hipaa = JSON.parse(fs.readFileSync(HIPAA_JSON_PATH, 'utf-8'));
    // Use checklist array (more complete than requirements: 35 vs 25 entries)
    for (const cfr of cfrSections) {
      const item = hipaa.checklist?.find((c: any) => c.id === cfr);
      if (item) return item.text.split('—')[0]?.trim() || item.text;
    }
    // Fallback to requirements
    for (const cfr of cfrSections) {
      const req = hipaa.requirements?.find((r: any) => r.id === cfr);
      if (req) return req.name;
    }
    return null;
  } catch { return null; }
}

/** Check if input looks like a HIPAA CFR section (e.g., 164.312(a)(2)(iv)) */
function isCFRSection(input: string): boolean {
  return /^164\.\d{3}/.test(input);
}

// ─── Schema ─────────────────────────────────────────────────

const SCHEMA = `
CREATE TABLE IF NOT EXISTS metadata (
  key            TEXT PRIMARY KEY,
  value          TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS controls (
  oscal_id       TEXT PRIMARY KEY,
  title          TEXT NOT NULL,
  family         TEXT NOT NULL,
  nist_prose     TEXT NOT NULL,
  nist_assess    TEXT,
  framework_refs TEXT NOT NULL,
  applicability  TEXT DEFAULT 'required',
  status         TEXT DEFAULT 'pending',
  updated_at     TEXT
);

CREATE TABLE IF NOT EXISTS evidence (
  id             INTEGER PRIMARY KEY AUTOINCREMENT,
  control_id     TEXT NOT NULL REFERENCES controls(oscal_id),
  type           TEXT NOT NULL,
  source         TEXT NOT NULL,
  content        TEXT NOT NULL,
  hash           TEXT NOT NULL,
  created_at     TEXT NOT NULL,
  signed         INTEGER DEFAULT 0,
  signature      TEXT
);

CREATE TABLE IF NOT EXISTS check_results (
  id             INTEGER PRIMARY KEY AUTOINCREMENT,
  control_id     TEXT NOT NULL REFERENCES controls(oscal_id),
  tool           TEXT NOT NULL,
  check_id       TEXT NOT NULL,
  result         TEXT NOT NULL,
  output         TEXT,
  created_at     TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS signatures (
  id             INTEGER PRIMARY KEY AUTOINCREMENT,
  control_id     TEXT,
  signer         TEXT NOT NULL,
  signer_type    TEXT NOT NULL,
  statement      TEXT,
  key_fingerprint TEXT,
  signature      TEXT NOT NULL,
  created_at     TEXT NOT NULL
);

CREATE INDEX IF NOT EXISTS idx_evidence_control ON evidence(control_id);
CREATE INDEX IF NOT EXISTS idx_checks_control ON check_results(control_id);
CREATE INDEX IF NOT EXISTS idx_sigs_control ON signatures(control_id);
`;

// ─── Subcommands ────────────────────────────────────────────

function migrateSchema(db: InstanceType<typeof Database>) {
  // Add columns for orchestrator support (backward compatible)
  const addColumnSafe = (table: string, column: string, type: string) => {
    try {
      db.exec(`ALTER TABLE ${table} ADD COLUMN ${column} ${type}`);
    } catch {
      // Column already exists — ignore
    }
  };
  addColumnSafe('check_results', 'severity', 'TEXT');
  addColumnSafe('check_results', 'resource', 'TEXT');
  addColumnSafe('check_results', 'scan_id', 'TEXT');
  addColumnSafe('compliance_baselines', 'cross_framework_scores', 'TEXT');

  // Compliance baselines for drift detection
  db.exec(`
    CREATE TABLE IF NOT EXISTS compliance_baselines (
      id             INTEGER PRIMARY KEY AUTOINCREMENT,
      snapshot_at    TEXT DEFAULT (datetime('now')),
      total_controls INTEGER,
      passing        INTEGER,
      failing        INTEGER,
      score          REAL,
      tool_versions  TEXT
    );
  `);

  // Audit simulation tables (for /hipaa-audit)
  db.exec(`
    CREATE TABLE IF NOT EXISTS audit_snapshots (
      id               INTEGER PRIMARY KEY AUTOINCREMENT,
      audit_type       TEXT NOT NULL,
      current_phase    INTEGER DEFAULT 1,
      grade            TEXT,
      total_findings   INTEGER DEFAULT 0,
      critical_findings INTEGER DEFAULT 0,
      major_findings   INTEGER DEFAULT 0,
      minor_findings   INTEGER DEFAULT 0,
      observation_findings INTEGER DEFAULT 0,
      created_at       TEXT DEFAULT (datetime('now')),
      completed_at     TEXT
    );
  `);
  db.exec(`
    CREATE TABLE IF NOT EXISTS audit_findings (
      id               INTEGER PRIMARY KEY AUTOINCREMENT,
      snapshot_id      INTEGER NOT NULL REFERENCES audit_snapshots(id),
      finding_number   INTEGER NOT NULL,
      control_id       TEXT NOT NULL,
      check_id         TEXT,
      hipaa_section    TEXT,
      severity         TEXT NOT NULL,
      description      TEXT NOT NULL,
      cfr_reference    TEXT,
      entity_response  TEXT,
      entity_response_text TEXT,
      created_at       TEXT DEFAULT (datetime('now'))
    );
  `);
  db.exec(`CREATE INDEX IF NOT EXISTS idx_audit_findings_snapshot ON audit_findings(snapshot_id);`);

  // Onboarding tables (for comply-start)
  db.exec(`
    CREATE TABLE IF NOT EXISTS phi_data_flows (
      id                INTEGER PRIMARY KEY AUTOINCREMENT,
      source            TEXT NOT NULL,
      destination       TEXT NOT NULL,
      data_type         TEXT NOT NULL,
      encryption_status TEXT,
      notes             TEXT,
      created_at        TEXT DEFAULT (datetime('now'))
    );
  `);
  db.exec(`
    CREATE TABLE IF NOT EXISTS vendor_registry (
      id                INTEGER PRIMARY KEY AUTOINCREMENT,
      vendor            TEXT NOT NULL,
      services_used     TEXT,
      baa_status        TEXT DEFAULT 'unknown',
      phi_scope         TEXT,
      detected_from     TEXT,
      confirmed_by_user INTEGER DEFAULT 0,
      notes             TEXT,
      created_at        TEXT DEFAULT (datetime('now'))
    );
  `);
  db.exec(`
    CREATE TABLE IF NOT EXISTS action_items (
      id                INTEGER PRIMARY KEY AUTOINCREMENT,
      priority          INTEGER NOT NULL,
      control_id        TEXT,
      description       TEXT NOT NULL,
      effort            TEXT,
      status            TEXT DEFAULT 'pending',
      phase             TEXT,
      created_at        TEXT DEFAULT (datetime('now'))
    );
  `);

  // Journey milestones for guided compliance journey
  db.exec(`
    CREATE TABLE IF NOT EXISTS journey_milestones (
      milestone_id       INTEGER PRIMARY KEY,
      name               TEXT NOT NULL,
      status             TEXT DEFAULT 'LOCKED',
      started_at         TEXT,
      completed_at       TEXT,
      evidence_count     INTEGER DEFAULT 0,
      needs_revalidation INTEGER DEFAULT 0
    );
  `);
}

function init() {
  const db = openDb();
  db.exec(SCHEMA);
  migrateSchema(db);

  const catalog = loadNistCatalog();
  const filter = loadFilter();

  // Collect unique control IDs from the filter
  // framework_refs stores as {"hipaa": ["164.312(a)(1)"], "soc2": ["CC6.1"]}
  // so multiple frameworks can share controls
  const controlIds = new Set<string>();
  const frameworkMap: Record<string, Record<string, string[]>> = {};
  for (const [spec, controls] of Object.entries(filter.mapping)) {
    for (const id of controls as string[]) {
      controlIds.add(id);
      if (!frameworkMap[id]) frameworkMap[id] = {};
      if (!frameworkMap[id][FRAMEWORK]) frameworkMap[id][FRAMEWORK] = [];
      frameworkMap[id][FRAMEWORK].push(spec);
    }
  }

  // If DB already has controls from another framework, merge refs
  const existingControls = db.prepare('SELECT oscal_id, framework_refs FROM controls').all() as any[];
  for (const existing of existingControls) {
    if (frameworkMap[existing.oscal_id]) {
      const existingRefs = JSON.parse(existing.framework_refs || '{}');
      frameworkMap[existing.oscal_id] = { ...existingRefs, ...frameworkMap[existing.oscal_id] };
    }
  }

  // Store catalog version metadata
  const catalogVersion = catalog.catalog?.metadata?.['oscal-version'] || 'unknown';
  const catalogTitle = catalog.catalog?.metadata?.title || 'NIST SP 800-53';
  const catalogModified = catalog.catalog?.metadata?.['last-modified'] || 'unknown';
  const metaInsert = db.prepare('INSERT OR REPLACE INTO metadata (key, value) VALUES (?, ?)');
  metaInsert.run('catalog_version', catalogVersion);
  metaInsert.run('catalog_title', catalogTitle);
  metaInsert.run('catalog_last_modified', catalogModified);
  metaInsert.run('framework', FRAMEWORK);
  metaInsert.run('filter_version', filter.version || '1.0');
  metaInsert.run('initialized_at', new Date().toISOString());

  // Track active frameworks (append, don't overwrite)
  const existingRow = db.prepare("SELECT value FROM metadata WHERE key = 'active_frameworks'").get() as any;
  const activeList: string[] = existingRow ? JSON.parse(existingRow.value) : [];
  if (!activeList.includes(FRAMEWORK)) activeList.push(FRAMEWORK);
  metaInsert.run('active_frameworks', JSON.stringify(activeList));

  // Import controls from NIST catalog
  const insert = db.prepare(`INSERT OR REPLACE INTO controls (oscal_id, title, family, nist_prose, nist_assess, framework_refs, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)`);

  let imported = 0;
  let missing = 0;
  const tx = db.transaction(() => {
    for (const id of controlIds) {
      const { prose, assess, title, family } = extractControlProse(catalog, id);
      if (!prose && !title) {
        console.error(`  WARNING: Control ${id} not found in NIST catalog`);
        missing++;
        continue;
      }
      const refs = JSON.stringify(frameworkMap[id] || []);
      insert.run(id, title, family, prose || '(no prose)', assess || '', refs, new Date().toISOString());
      imported++;
    }
  });
  tx();
  db.close();

  console.log(`DB_INITIALIZED: ${getDbPath()}`);
  console.log(`  Imported: ${imported} controls from NIST 800-53`);
  if (missing > 0) console.log(`  Missing:  ${missing} controls not found in catalog`);
  console.log(`  Filter specs: ${Object.keys(filter.mapping).length} (${FRAMEWORK})`);
  if (filter.maturity === 'community' || filter.maturity === 'stub') {
    console.log(`  WARNING: ${FRAMEWORK} mapping is community-maintained and has not been validated by a domain expert.`);
  }
  if (filter.structural_limitations) {
    console.log(`  NOTE: ${filter.structural_limitations.slice(0, 200)}${filter.structural_limitations.length > 200 ? '...' : ''}`);
  }
}

function status() {
  const db = openDb();
  const controls = db.prepare('SELECT oscal_id, title, family, status, framework_refs FROM controls ORDER BY oscal_id').all() as any[];

  if (controls.length === 0) {
    console.error('No controls. Run: comply-db init');
    process.exit(1);
  }

  console.log(`\nCompliance Status — ${getSlug()}`);
  console.log('═'.repeat(85));
  console.log(`${'Control'.padEnd(8)} ${'Title'.padEnd(40)} ${'Family'.padEnd(20)} Status`);
  console.log('─'.repeat(85));

  for (const c of controls) {
    const title = c.title.substring(0, 38).padEnd(40);
    const family = c.family.substring(0, 18).padEnd(20);
    console.log(`${c.oscal_id.padEnd(8)} ${title} ${family} ${c.status}`);
  }

  const total = controls.length;
  const complete = controls.filter((c: any) => c.status === 'complete').length;
  const partial = controls.filter((c: any) => c.status === 'partial').length;
  const pending = controls.filter((c: any) => c.status === 'pending').length;
  const pct = Math.round((complete / total) * 100);

  console.log('─'.repeat(85));
  console.log(`${total} controls | ${complete} complete (${pct}%) | ${partial} partial | ${pending} pending`);
  db.close();
}

function controlDetail() {
  const inputId = args[1];
  if (!inputId) { console.error('Usage: comply-db control <oscal_id|cfr_section> [--json] [--simple]'); process.exit(1); }

  const jsonMode = args.includes('--json');
  const simpleMode = args.includes('--simple');

  // CFR resolution: if input looks like a HIPAA CFR section, resolve to NIST control IDs
  let controlIds: string[];
  let resolvedFrom: string | null = null;
  if (isCFRSection(inputId)) {
    controlIds = resolveFromCFR(inputId);
    if (controlIds.length === 0) {
      console.error(`CFR section ${inputId} not found in hipaa-filter.json.`);
      process.exit(1);
    }
    resolvedFrom = inputId;
  } else {
    controlIds = [inputId];
  }

  // If multiple controls resolved from CFR, output each
  if (jsonMode && controlIds.length > 1) {
    const results = controlIds.map(id => buildControlData(id, resolvedFrom, simpleMode));
    console.log(JSON.stringify(results, null, 2));
    return;
  }

  // Single control (or first from CFR resolution for text mode)
  const oscalId = controlIds[0];

  if (jsonMode) {
    const data = buildControlData(oscalId, resolvedFrom, simpleMode);
    console.log(JSON.stringify(data, null, 2));
  } else {
    printControlText(oscalId);
  }
}

/** Build enriched data object for a single control */
function buildControlData(oscalId: string, resolvedFrom: string | null, simpleMode: boolean): any {
  // Normalize to uppercase for consistent lookups across data files
  oscalId = oscalId.toUpperCase();

  const dbPath = getDbPath();
  const sources: Record<string, string> = {};

  // Load NIST catalog (required)
  const catalog = loadNistCatalog();
  sources.nist_catalog = 'found';
  const catalogIndex = buildCatalogIndex(catalog);

  // Validate control exists in catalog
  if (!findControlInCatalog(catalog, oscalId)) {
    console.error(`Control ${oscalId} not found in NIST catalog.`);
    process.exit(1);
  }

  // Extract from catalog
  const { prose, assess, title, family } = extractControlProse(catalog, oscalId);
  const guidance = extractGuidance(catalog, oscalId);
  const relatedControls = extractRelatedControls(catalog, oscalId, catalogIndex);

  // Plain-English
  const pe = loadPlainEnglish(oscalId);
  sources.plain_english = pe ? 'found' : 'not_found';

  // HIPAA sections (reverse-map: NIST → CFR)
  let hipaaSections: string[] = [];
  try {
    const filterPath = path.join(NIST_DIR, 'hipaa-filter.json');
    if (fs.existsSync(filterPath)) {
      const filter = JSON.parse(fs.readFileSync(filterPath, 'utf-8'));
      for (const [spec, controls] of Object.entries(filter.mapping)) {
        if ((controls as string[]).some(c => c.toUpperCase() === oscalId)) {
          hipaaSections.push(spec);
        }
      }
      sources.hipaa_filter = 'found';
    } else {
      sources.hipaa_filter = 'not_found';
    }
  } catch { sources.hipaa_filter = 'error'; }

  // HIPAA name (from checklist, which is more complete than requirements)
  const hipaaName = getHipaaName(hipaaSections);

  // Verification normalization
  const verification = normalizeVerification(oscalId);
  sources.tool_bindings = verification !== null ? 'found' : 'not_found';

  // SQLite-dependent fields (single DB connection)
  let status = 'unknown';
  let evidenceCount = 0;
  let detectedStack: string[] = [];
  try {
    if (fs.existsSync(dbPath)) {
      const db = new Database(dbPath, { readonly: true });
      const ctrl = db.prepare('SELECT status FROM controls WHERE oscal_id = ?').get(oscalId) as any;
      if (ctrl) status = ctrl.status;
      const evCount = db.prepare('SELECT COUNT(*) as cnt FROM evidence WHERE control_id = ?').get(oscalId) as any;
      if (evCount) evidenceCount = evCount.cnt;
      // Read vendor_registry in the same connection
      try {
        const vendors = db.prepare('SELECT vendor FROM vendor_registry').all() as any[];
        detectedStack = vendors.map((v: any) => v.vendor).filter(Boolean);
      } catch { /* vendor_registry may not exist yet */ }
      db.close();
      sources.sqlite_db = 'found';
    } else {
      sources.sqlite_db = 'not_found';
    }
  } catch { sources.sqlite_db = 'error'; }

  return {
    control_id: oscalId,
    resolved_from: resolvedFrom,
    nist_name: title,
    family,
    plain_english: pe?.plain_english ?? null,
    why_it_matters: pe?.why_it_matters ?? null,
    nist_guidance: guidance || null,
    hipaa_sections: hipaaSections,
    hipaa_name: hipaaName,
    related_controls: relatedControls,
    status,
    evidence_count: evidenceCount,
    detected_stack: detectedStack,
    verification,
    eli5_requested: simpleMode,
    _sources: sources,
  };
}

/** Original text output for comply-db control (backwards compatible) */
function printControlText(oscalId: string) {
  const dbPath = getDbPath();
  if (!fs.existsSync(dbPath)) {
    console.error('No database. Run: comply-db init');
    process.exit(1);
  }

  const db = new Database(dbPath, { readonly: true });
  const ctrl = db.prepare('SELECT * FROM controls WHERE oscal_id = ?').get(oscalId) as any;
  if (!ctrl) {
    // Show valid IDs
    const all = db.prepare('SELECT oscal_id FROM controls ORDER BY oscal_id').all() as any[];
    db.close();
    const ids = all.map((r: any) => r.oscal_id);
    const preview = ids.slice(0, 10).join(', ');
    console.error(`Control ${oscalId} not found. Valid IDs (${ids.length} total): ${preview}${ids.length > 10 ? '...' : ''}`);
    process.exit(1);
  }

  const checks = db.prepare('SELECT * FROM check_results WHERE control_id = ? ORDER BY created_at DESC').all(oscalId) as any[];
  const evidence = db.prepare('SELECT * FROM evidence WHERE control_id = ? ORDER BY created_at DESC').all(oscalId) as any[];
  const sigs = db.prepare('SELECT * FROM signatures WHERE control_id = ? ORDER BY created_at DESC').all(oscalId) as any[];

  // Plain-English header
  const pe = loadPlainEnglish(oscalId);

  console.log(`\n═══ ${ctrl.oscal_id}: ${ctrl.title} ═══`);
  console.log(`Family: ${ctrl.family} | Status: ${ctrl.status}`);

  if (pe) {
    console.log(`\nPlain English: ${pe.plain_english}`);
    console.log(`Why it matters: ${pe.why_it_matters}`);
  }

  const refs = JSON.parse(ctrl.framework_refs || '{}');
  const refSummary = Object.entries(refs).map(([fw, specs]) => `${fw}: ${(specs as string[]).join(', ')}`).join(' | ');
  console.log(`Frameworks: ${refSummary}`);
  console.log(`\nNIST Statement:\n${ctrl.nist_prose}`);
  if (ctrl.nist_assess) console.log(`\nAssessment Method:\n${ctrl.nist_assess}`);

  if (checks.length > 0) {
    console.log(`\nCheck Results (${checks.length}):`);
    for (const c of checks) {
      let line = `  ${c.result.padEnd(6)} ${c.tool}:${c.check_id}`;
      if (c.severity) line += ` [${c.severity}]`;
      if (c.resource) line += ` ${c.resource}`;
      line += ` (${c.created_at})`;
      if (c.scan_id) line += ` scan:${c.scan_id}`;
      console.log(line);
    }
  }

  if (evidence.length > 0) {
    console.log(`\nEvidence (${evidence.length}):`);
    for (const e of evidence) console.log(`  ${e.type} from ${e.source}: ${e.content.substring(0, 80)}...`);
  }

  if (sigs.length > 0) {
    console.log(`\nSignatures (${sigs.length}):`);
    for (const s of sigs) console.log(`  ${s.signer_type}: ${s.signer} (${s.created_at})`);
  }

  db.close();
}

function summary() {
  const db = openDb();
  const controls = db.prepare('SELECT status FROM controls').all() as any[];
  const checks = db.prepare('SELECT result, COUNT(*) as cnt FROM check_results GROUP BY result').all() as any[];
  const evidenceCount = db.prepare('SELECT COUNT(*) as cnt FROM evidence').get() as any;
  const sigCount = db.prepare('SELECT COUNT(*) as cnt FROM signatures').get() as any;

  const total = controls.length;
  const complete = controls.filter((c: any) => c.status === 'complete').length;
  const pct = Math.round((complete / total) * 100);

  console.log(`\nCompliance Summary — ${getSlug()}`);
  console.log('═'.repeat(50));
  console.log(`  Controls:    ${total} total, ${complete} complete (${pct}%)`);
  for (const c of checks) console.log(`  Checks:      ${c.cnt} ${c.result}`);
  console.log(`  Evidence:    ${evidenceCount.cnt} items`);
  console.log(`  Signatures:  ${sigCount.cnt}`);
  db.close();
}

function updateScan() {
  const oscalId = args[1];
  const result = args[2]?.toUpperCase();
  const tool = args[3] || 'emdash';
  const checkId = args[4] || oscalId;
  const output = args[5] || '';
  const severity = getFlag('severity') || '';
  const resource = getFlag('resource') || '';
  const scanId = getFlag('scan-id') || '';

  if (!oscalId || !result) { console.error('Usage: comply-db update-scan <oscal_id> <PASS|FAIL> [tool] [check_id] [output] [--severity X] [--resource X] [--scan-id X]'); process.exit(1); }

  const db = openDb();
  db.prepare('INSERT INTO check_results (control_id, tool, check_id, result, output, severity, resource, scan_id, created_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)').run(oscalId, tool, checkId, result, output, severity, resource, scanId, new Date().toISOString());

  // Derive control status from check results instead of hard-setting to 'partial'
  const results = db.prepare('SELECT result FROM check_results WHERE control_id = ?').all(oscalId) as any[];
  const allPass = results.length > 0 && results.every((r: any) => r.result === 'PASS');
  const derivedStatus = allPass ? 'complete' : (results.length > 0 ? 'partial' : 'pending');
  db.prepare("UPDATE controls SET status = ?, updated_at = ? WHERE oscal_id = ?").run(derivedStatus, new Date().toISOString(), oscalId);

  db.close();
  console.log(`CHECK_RECORDED: ${oscalId} ${tool}:${checkId} → ${result} (control: ${derivedStatus})`);
}

function signControl() {
  const oscalId = args[1];
  const name = getFlag('name') || process.env.USER || 'unknown';
  const role = getFlag('role') || 'unspecified';
  const statement = getFlag('statement') || args[2] || 'I attest that the evidence for this control is accurate and complete.';

  if (!oscalId) { console.error('Usage: comply-db sign <oscal_id> [--name "Jane Smith"] [--role "Security Officer"] [--statement "..."]'); process.exit(1); }

  // Load signing key
  const keysDir = path.join(process.env.HOME ?? '', '.em-dash', 'keys');
  const privatePath = path.join(keysDir, 'default.pem');

  if (!fs.existsSync(privatePath)) {
    console.error('No signing key. Run: bin/comply-attest init-keys');
    process.exit(1);
  }

  const crypto = require('crypto');
  const canonicalize = require('canonicalize');

  const privateKey = crypto.createPrivateKey(fs.readFileSync(privatePath, 'utf-8'));
  const publicKey = crypto.createPublicKey(privateKey);
  const fp = 'ed25519:' + crypto.createHash('sha256')
    .update(publicKey.export({ type: 'spki', format: 'der' }))
    .digest('hex').slice(0, 16);

  // Build the attestation payload
  const payload = {
    type: 'user-attestation',
    version: '1.0',
    control_id: oscalId,
    signer: name,
    signer_role: role,
    signer_type: 'user',
    statement,
    key_fingerprint: fp,
    created_at: new Date().toISOString(),
  };

  // Sign with RFC 8785 canonicalization
  const canonical = canonicalize(payload);
  const sig = crypto.sign(null, Buffer.from(canonical), privateKey).toString('base64');

  // Store in SQLite
  const db = openDb();
  db.prepare('INSERT INTO signatures (control_id, signer, signer_type, statement, key_fingerprint, signature, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)').run(
    oscalId, name, 'user', statement, fp, sig, payload.created_at,
  );

  // Also write file-based attestation for audit packets
  const slug = getSlug();
  const attestDir = path.join(process.env.HOME ?? '', '.em-dash', 'projects', slug, 'attestations');
  if (!fs.existsSync(attestDir)) fs.mkdirSync(attestDir, { recursive: true });
  const attestPath = path.join(attestDir, `user-${oscalId}-${Date.now()}.json`);
  fs.writeFileSync(attestPath, JSON.stringify({ ...payload, signature: sig }, null, 2));

  db.close();

  console.log(`USER_SIGNED: ${oscalId} by ${name} (${role}) — ${fp}`);
  console.log(`Statement: ${statement}`);
  console.log(`Attestation: ${attestPath}`);
}

function validateTools() {
  const bindingsPath = path.join(NIST_DIR, 'tool-bindings.json');
  if (!fs.existsSync(bindingsPath)) { console.error('Tool bindings not found'); process.exit(1); }
  const bindings = JSON.parse(fs.readFileSync(bindingsPath, 'utf-8'));

  // Validate em-dash checks against registry
  const registryPath = path.join(import.meta.dir, '..', 'frameworks', 'checks-registry.ts');
  const registryContent = fs.readFileSync(registryPath, 'utf-8');
  const regIds = new Set<string>();
  const re = /id:\s*['"]([^'"]+)['"]/g;
  let m;
  while ((m = re.exec(registryContent)) !== null) regIds.add(m[1]);

  let errors = 0;
  let prowlerCount = 0;
  let checkovCount = 0;
  const prowlerIds = new Set<string>();
  const checkovIds = new Set<string>();
  const trivyIds = new Set<string>();

  for (const [controlId, tools] of Object.entries(bindings.bindings)) {
    const t = tools as any;

    // Validate em-dash checks
    for (const checkId of t.emdash || []) {
      if (!regIds.has(checkId)) {
        console.error(`  ERROR: ${controlId} references unknown em-dash check '${checkId}'`);
        errors++;
      }
    }

    // Count external tool references
    for (const id of t.prowler || []) { prowlerIds.add(id); prowlerCount++; }
    for (const id of t.checkov || []) { checkovIds.add(id); checkovCount++; }
    for (const id of t.trivy || []) { trivyIds.add(id); }
  }

  // Validate Prowler IDs if prowler is installed
  const prowlerInstalled = Bun.spawnSync(['which', 'prowler'], { stdout: 'pipe' }).exitCode === 0;
  if (prowlerInstalled && prowlerIds.size > 0) {
    console.log('  Validating Prowler check IDs...');
    const proc = Bun.spawnSync(['prowler', '--list-checks-json'], { stdout: 'pipe', stderr: 'pipe' });
    if (proc.exitCode === 0) {
      try {
        const checks = JSON.parse(new TextDecoder().decode(proc.stdout));
        const validProwler = new Set(checks.map((c: any) => c.CheckID || c.check_id || c.id));
        for (const id of prowlerIds) {
          if (!validProwler.has(id)) {
            console.error(`  WARNING: Prowler check '${id}' not found in installed version`);
          }
        }
      } catch {
        console.log('  Could not parse Prowler check list — skipping validation');
      }
    }
  } else if (prowlerIds.size > 0) {
    console.log(`  Prowler not installed — ${prowlerIds.size} check IDs not validated`);
  }

  // Validate Checkov IDs if checkov is installed
  const checkovInstalled = Bun.spawnSync(['which', 'checkov'], { stdout: 'pipe' }).exitCode === 0;
  if (checkovInstalled && checkovIds.size > 0) {
    console.log('  Validating Checkov check IDs...');
    const proc = Bun.spawnSync(['checkov', '--list'], { stdout: 'pipe', stderr: 'pipe' });
    if (proc.exitCode === 0) {
      const output = new TextDecoder().decode(proc.stdout);
      for (const id of checkovIds) {
        if (!output.includes(id)) {
          console.error(`  WARNING: Checkov check '${id}' not found in installed version`);
        }
      }
    }
  } else if (checkovIds.size > 0) {
    console.log(`  Checkov not installed — ${checkovIds.size} check IDs not validated`);
  }

  console.log(`\nTool Binding Validation:`);
  console.log(`  Controls: ${Object.keys(bindings.bindings).length}`);
  console.log(`  em-dash checks: ${regIds.size} in registry, ${errors} invalid references`);
  console.log(`  Prowler refs: ${prowlerIds.size} unique IDs ${prowlerInstalled ? '(validated)' : '(not validated — install prowler)'}`);
  console.log(`  Checkov refs: ${checkovIds.size} unique IDs ${checkovInstalled ? '(validated)' : '(not validated — install checkov)'}`);
  console.log(`  Trivy refs: ${trivyIds.size} unique AVD IDs`);

  if (errors > 0) process.exit(1);
}

function rawQuery() {
  const sql = args.slice(1).join(' ');
  if (!sql) { console.error('Usage: comply-db query "SELECT ..."'); process.exit(1); }
  const db = openDb();
  try {
    const rows = db.prepare(sql).all();
    console.log(JSON.stringify(rows, null, 2));
  } catch (e: any) {
    console.error(e.message);
    process.exit(1);
  }
  db.close();
}

// ─── Active Frameworks ──────────────────────────────────────

function getActiveFrameworksList(): string[] {
  try {
    const db = openDb();
    const row = db.prepare("SELECT value FROM metadata WHERE key = 'active_frameworks'").get() as any;
    if (!row) {
      // Legacy fallback: single 'framework' key
      const legacy = db.prepare("SELECT value FROM metadata WHERE key = 'framework'").get() as any;
      db.close();
      return legacy ? [legacy.value] : [];
    }
    db.close();
    return JSON.parse(row.value);
  } catch {
    return [];
  }
}

function frameworks() {
  const add = getFlag('add');
  const remove = getFlag('remove');

  if (add) {
    if (!/^[a-z0-9-]+$/.test(add)) { console.error(`Invalid framework name: ${add}`); process.exit(1); }
    const filterPath = path.join(NIST_DIR, `${add}-filter.json`);
    if (!fs.existsSync(filterPath)) { console.error(`No filter file for ${add}. Available: ${fs.readdirSync(NIST_DIR).filter(f => f.endsWith('-filter.json')).map(f => f.replace('-filter.json', '')).join(', ')}`); process.exit(1); }
    const db = openDb();
    const row = db.prepare("SELECT value FROM metadata WHERE key = 'active_frameworks'").get() as any;
    const active: string[] = row ? JSON.parse(row.value) : [];
    if (!active.includes(add)) {
      active.push(add);
      db.prepare("INSERT OR REPLACE INTO metadata (key, value) VALUES ('active_frameworks', ?)").run(JSON.stringify(active));
      console.log(`Added ${add}. Active: ${active.join(', ')}`);
    } else {
      console.log(`${add} already active. Active: ${active.join(', ')}`);
    }
    db.close();
    return;
  }

  if (remove) {
    const db = openDb();
    const row = db.prepare("SELECT value FROM metadata WHERE key = 'active_frameworks'").get() as any;
    const active: string[] = row ? JSON.parse(row.value) : [];
    const filtered = active.filter(f => f !== remove);
    db.prepare("INSERT OR REPLACE INTO metadata (key, value) VALUES ('active_frameworks', ?)").run(JSON.stringify(filtered));
    console.log(`Removed ${remove}. Active: ${filtered.join(', ') || '(none)'}`);
    db.close();
    return;
  }

  // List
  const active = getActiveFrameworksList();
  if (active.length === 0) {
    console.log('No active frameworks. Run /hipaa, /soc2, etc. to initialize.');
  } else {
    console.log(`Active frameworks: ${active.join(', ')}`);
    console.log(`Available: hipaa, soc2, gdpr, pci-dss, cis, iso27001`);
  }
}

// ─── Cross-Framework Matrix ─────────────────────────────────

function crossFramework() {
  const { buildCrossFrameworkMatrix, formatMatrixTable } = require(path.join(import.meta.dir, '..', 'nist', 'cross-framework.ts'));
  const showAll = args.includes('--all');
  const active = showAll ? [] : getActiveFrameworksList();
  // If no active frameworks or --all, show all (backward compat for CLI)
  const matrix = buildCrossFrameworkMatrix(active.length > 0 ? active : undefined);
  const format = getFlag('format') || 'table';

  if (format === 'json') {
    console.log(JSON.stringify(matrix, null, 2));
  } else {
    console.log(formatMatrixTable(matrix));
  }
}

// ─── CIS Coverage Gap Report ────────────────────────────────

function cisCoverage() {
  // CIS AWS Foundations Benchmark v3.0 Level 1 automated recommendations
  // IDs only — all descriptions independently written (OpenSCAP model)
  const CIS_AWS_LEVEL1: Array<{ id: string; section: string; description: string }> = [
    { id: '1.4', section: 'IAM', description: 'Ensure no root account access key exists' },
    { id: '1.5', section: 'IAM', description: 'Ensure MFA is enabled for root account' },
